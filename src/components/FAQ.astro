---
export interface Props {
  items: { q: string; a: string }[];
}
const { items } = Astro.props;
---

<div class="space-y-3">
  {items.map((item, idx) => (
    <details class="group border-b border-[var(--color-rule)] pb-3">
      <summary class="flex justify-between items-start cursor-pointer list-none py-2 gap-4">
        <span class="font-medium text-[var(--color-ink)] pr-4">{item.q}</span>
        <svg
          width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.75"
          class="text-[var(--color-ink-muted)] shrink-0 mt-1 transition-transform group-open:rotate-45"
        >
          <path d="M12 5v14M5 12h14" stroke-linecap="round" />
        </svg>
      </summary>
      <div class="text-[var(--color-ink-soft)] leading-relaxed mt-2 pr-8">
        {item.a}
      </div>
    </details>
  ))}
</div>
