---
import type { Tool } from "../data/tools";
export interface Props { tool: Tool }
const { tool } = Astro.props;
const isLive = tool.status === "live";
const Tag = isLive ? "a" : "div";
const href = isLive ? `/tools/${tool.slug}` : undefined;
---

<Tag
  href={href}
  class:list={[
    "block group p-5 rounded-lg border border-[var(--color-rule)] bg-[var(--color-paper)] transition-all",
    isLive
      ? "hover:border-[var(--color-accent)] hover:-translate-y-0.5 hover:shadow-sm cursor-pointer"
      : "opacity-60 cursor-default",
  ]}
>
  <div class="flex items-start justify-between mb-3">
    <div class:list={[
      "w-10 h-10 rounded-md flex items-center justify-center transition-colors",
      isLive ? "bg-[var(--color-accent-tint)] text-[var(--color-accent)]" : "bg-[var(--color-paper-dark)] text-[var(--color-ink-muted)]",
    ]}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <path d={tool.icon} stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
    {!isLive && (
      <span class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] font-medium">Soon</span>
    )}
  </div>
  <h3 class="font-medium text-[var(--color-ink)] mb-1.5">{tool.name}</h3>
  <p class="text-sm text-[var(--color-ink-muted)] leading-relaxed">{tool.description}</p>
</Tag>
