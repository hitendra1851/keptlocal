---
// PDF Merge — runs entirely in the browser via pdf-lib loaded as ESM
---

<div
  id="pdf-merge-app"
  class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]"
>
  <!-- Drop zone -->
  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" multiple accept="application/pdf,.pdf" class="hidden" />

    <div id="empty-state">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M9 12h6m-6 4h6m-7-8h.01M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop PDFs here, or</p>
      <button type="button" id="browse-btn" class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">
        choose files from your device
      </button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">
        Add 2 or more PDFs. Drag to reorder. Files never leave your browser.
      </p>
    </div>
  </div>

  <!-- File list -->
  <div id="file-list-wrap" class="hidden px-4 pb-4">
    <div class="flex items-center justify-between mb-3 px-1">
      <h3 class="text-sm font-medium text-[var(--color-ink-soft)]">
        <span id="file-count">0</span> files queued
      </h3>
      <button type="button" id="clear-btn" class="text-xs text-[var(--color-ink-muted)] hover:text-[var(--color-warn)]">
        Clear all
      </button>
    </div>
    <ul id="file-list" class="space-y-2"></ul>

    <button type="button" id="add-more-btn" class="mt-3 w-full py-2.5 border border-dashed border-[var(--color-rule)] rounded-md text-sm text-[var(--color-ink-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors">
      + Add more PDFs
    </button>
  </div>

  <!-- Action bar -->
  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <div id="status-msg" class="text-sm text-[var(--color-ink-muted)] min-h-[1.25rem]">
      Add at least 2 PDFs to merge.
    </div>
    <button type="button" id="merge-btn" class="btn-primary" disabled>
      <span id="merge-btn-label">Merge & download</span>
      <svg id="merge-spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12a9 9 0 11-6.219-8.56" />
      </svg>
    </button>
  </div>
</div>

<!-- pdf-lib loaded as ESM from CDN. Pinned version, integrity-checked at build time by browser. -->
<script type="module">
  import { PDFDocument } from "https://esm.sh/pdf-lib@1.17.1";

  /** @type {Array<{ id: string, name: string, size: number, bytes: ArrayBuffer }>} */
  let files = [];
  let merging = false;

  const $ = (id) => document.getElementById(id);
  const dropZone = $("drop-zone");
  const fileInput = $("file-input");
  const browseBtn = $("browse-btn");
  const addMoreBtn = $("add-more-btn");
  const clearBtn = $("clear-btn");
  const mergeBtn = $("merge-btn");
  const mergeLabel = $("merge-btn-label");
  const spinner = $("merge-spinner");
  const statusMsg = $("status-msg");
  const fileListWrap = $("file-list-wrap");
  const fileList = $("file-list");
  const fileCount = $("file-count");
  const emptyState = $("empty-state");

  const fmtSize = (b) => {
    if (b < 1024) return `${b} B`;
    if (b < 1024 * 1024) return `${(b / 1024).toFixed(1)} KB`;
    return `${(b / 1024 / 1024).toFixed(1)} MB`;
  };

  const setStatus = (msg, isError = false) => {
    statusMsg.textContent = msg;
    statusMsg.style.color = isError ? "var(--color-warn)" : "";
  };

  const render = () => {
    fileCount.textContent = String(files.length);
    if (files.length === 0) {
      emptyState.classList.remove("hidden");
      fileListWrap.classList.add("hidden");
      mergeBtn.disabled = true;
      setStatus("Add at least 2 PDFs to merge.");
      return;
    }

    emptyState.classList.add("hidden");
    fileListWrap.classList.remove("hidden");
    mergeBtn.disabled = files.length < 2 || merging;

    fileList.innerHTML = "";
    files.forEach((f, idx) => {
      const li = document.createElement("li");
      li.draggable = true;
      li.dataset.id = f.id;
      li.className =
        "flex items-center gap-3 px-3 py-2.5 bg-[var(--color-paper-dark)] rounded-md border border-transparent hover:border-[var(--color-rule)] cursor-grab active:cursor-grabbing transition-colors";
      li.innerHTML = `
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="text-[var(--color-ink-muted)] shrink-0">
          <path d="M8 9h.01M16 9h.01M8 15h.01M16 15h.01M4 6h16M4 12h16M4 18h16" />
        </svg>
        <span class="text-xs text-[var(--color-ink-muted)] tabular-nums w-5">${idx + 1}</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-accent)] shrink-0">
          <path d="M9 12h6m-6 4h6m-7-8h.01M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <div class="flex-1 min-w-0">
          <div class="text-sm text-[var(--color-ink)] truncate">${f.name}</div>
          <div class="text-xs text-[var(--color-ink-muted)]">${fmtSize(f.size)}</div>
        </div>
        <button type="button" data-remove="${f.id}" class="p-1.5 rounded hover:bg-[var(--color-paper)] text-[var(--color-ink-muted)] hover:text-[var(--color-warn)]" aria-label="Remove">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" />
          </svg>
        </button>
      `;
      fileList.appendChild(li);
    });

    if (files.length < 2) {
      setStatus("Add at least 1 more PDF to enable merging.");
    } else {
      setStatus(`Ready: ${files.length} files in this order.`);
    }
  };

  // ---- File ingestion ----
  const addFiles = async (incoming) => {
    const pdfs = Array.from(incoming).filter(
      (f) => f.type === "application/pdf" || f.name.toLowerCase().endsWith(".pdf")
    );
    if (pdfs.length === 0) {
      setStatus("Only PDF files are accepted.", true);
      return;
    }
    for (const file of pdfs) {
      const bytes = await file.arrayBuffer();
      files.push({
        id: crypto.randomUUID(),
        name: file.name,
        size: file.size,
        bytes,
      });
    }
    render();
  };

  // ---- Events ----
  browseBtn?.addEventListener("click", () => fileInput.click());
  addMoreBtn?.addEventListener("click", () => fileInput.click());
  dropZone.addEventListener("click", (e) => {
    if (e.target === dropZone || e.target === emptyState) fileInput.click();
  });

  fileInput.addEventListener("change", (e) => {
    if (e.target.files) addFiles(e.target.files);
    fileInput.value = "";
  });

  ["dragenter", "dragover"].forEach((ev) =>
    dropZone.addEventListener(ev, (e) => {
      e.preventDefault();
      dropZone.classList.add("dragging");
    })
  );
  ["dragleave", "drop"].forEach((ev) =>
    dropZone.addEventListener(ev, (e) => {
      e.preventDefault();
      dropZone.classList.remove("dragging");
    })
  );
  dropZone.addEventListener("drop", (e) => {
    if (e.dataTransfer?.files) addFiles(e.dataTransfer.files);
  });

  // Remove individual file
  fileList.addEventListener("click", (e) => {
    const btn = e.target.closest("button[data-remove]");
    if (!btn) return;
    const id = btn.dataset.remove;
    files = files.filter((f) => f.id !== id);
    render();
  });

  clearBtn?.addEventListener("click", () => {
    files = [];
    render();
  });

  // Drag-to-reorder
  let draggedId = null;
  fileList.addEventListener("dragstart", (e) => {
    const li = e.target.closest("li");
    if (!li) return;
    draggedId = li.dataset.id;
    li.style.opacity = "0.4";
  });
  fileList.addEventListener("dragend", (e) => {
    const li = e.target.closest("li");
    if (li) li.style.opacity = "";
  });
  fileList.addEventListener("dragover", (e) => e.preventDefault());
  fileList.addEventListener("drop", (e) => {
    e.preventDefault();
    const targetLi = e.target.closest("li");
    if (!targetLi || !draggedId) return;
    const targetId = targetLi.dataset.id;
    if (targetId === draggedId) return;

    const fromIdx = files.findIndex((f) => f.id === draggedId);
    const toIdx = files.findIndex((f) => f.id === targetId);
    const [moved] = files.splice(fromIdx, 1);
    files.splice(toIdx, 0, moved);
    draggedId = null;
    render();
  });

  // ---- Merge ----
  mergeBtn.addEventListener("click", async () => {
    if (files.length < 2 || merging) return;
    merging = true;
    mergeBtn.disabled = true;
    spinner.classList.remove("hidden");
    mergeLabel.textContent = "Merging...";
    setStatus("Working in your browser — this may take a moment.");

    try {
      const merged = await PDFDocument.create();
      for (let i = 0; i < files.length; i++) {
        setStatus(`Reading ${i + 1} of ${files.length}: ${files[i].name}`);
        const src = await PDFDocument.load(files[i].bytes, { ignoreEncryption: true });
        const pages = await merged.copyPages(src, src.getPageIndices());
        pages.forEach((p) => merged.addPage(p));
      }
      setStatus("Saving merged PDF...");
      const out = await merged.save();

      // Trigger download
      const blob = new Blob([out], { type: "application/pdf" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = `merged-${new Date().toISOString().slice(0, 10)}.pdf`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);

      setStatus(`✓ Done. Downloaded merged PDF (${files.length} files combined).`);
    } catch (err) {
      console.error(err);
      setStatus(
        `Error: ${err?.message || "could not merge — check that all files are valid PDFs."}`,
        true
      );
    } finally {
      merging = false;
      spinner.classList.add("hidden");
      mergeLabel.textContent = "Merge & download";
      mergeBtn.disabled = files.length < 2;
    }
  });

  // Block accidental page leave during merge
  window.addEventListener("beforeunload", (e) => {
    if (merging) {
      e.preventDefault();
      e.returnValue = "";
    }
  });
</script>
