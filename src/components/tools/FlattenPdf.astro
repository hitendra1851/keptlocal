---
// Flatten PDF — pdf-lib form.flatten(). Locks form fields. No upload.
---

<div id="flatten-app" class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]">

  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" accept="application/pdf,.pdf" class="hidden" />
    <div id="empty-state" class="text-center py-4">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
        class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop a PDF here, or</p>
      <button id="browse-btn" type="button"
        class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">
        choose a file
      </button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">PDF files only. Form fields and annotations are baked into page content. Runs entirely in your browser.</p>
    </div>
    <div id="file-ready" class="hidden text-center">
      <p id="file-name" class="text-sm font-medium text-[var(--color-ink)]"></p>
      <p id="file-size" class="text-xs text-[var(--color-ink-muted)] mt-0.5"></p>
      <button id="change-btn" type="button" class="text-xs text-[var(--color-accent)] mt-1 hover:underline">Change file</button>
    </div>
  </div>

  <div id="options-wrap" class="hidden px-4 pb-4 space-y-2">
    <p class="text-xs font-medium text-[var(--color-ink-muted)] uppercase tracking-wide">What gets flattened</p>
    <label class="flex items-center gap-2 text-sm text-[var(--color-ink)] cursor-pointer">
      <input type="checkbox" id="chk-fields" checked disabled class="accent-[var(--color-accent)]" />
      Form fields (text inputs, checkboxes, radio buttons, dropdowns)
    </label>
    <label class="flex items-center gap-2 text-sm text-[var(--color-ink)] cursor-pointer">
      <input type="checkbox" id="chk-annots" checked class="accent-[var(--color-accent)]" />
      Annotations (comments, highlights, stamps)
    </label>
    <p class="text-xs text-[var(--color-ink-muted)]">Flattening bakes interactive elements into static page content. The result cannot be edited as a form — this is intentional.</p>
  </div>

  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <p id="status-msg" class="text-sm text-[var(--color-ink-muted)]">Upload a PDF with form fields to flatten.</p>
    <button id="flatten-btn" type="button" class="btn-primary" disabled>
      <span id="btn-label">Flatten PDF</span>
      <svg id="spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12a9 9 0 11-6.219-8.56"/>
      </svg>
    </button>
  </div>
</div>

<script type="module">
import { PDFDocument } from 'https://esm.sh/pdf-lib@1.17.1';

let pdfFile = null;
const fileInput = document.getElementById('file-input');
const dropZone  = document.getElementById('drop-zone');
const flattenBtn = document.getElementById('flatten-btn');
const statusMsg  = document.getElementById('status-msg');

document.getElementById('browse-btn').addEventListener('click', () => fileInput.click());
document.getElementById('change-btn').addEventListener('click', () => reset());
fileInput.addEventListener('change', e => { if (e.target.files[0]) load(e.target.files[0]); });
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault(); dropZone.classList.remove('drag-over');
  const f = e.dataTransfer.files[0];
  if (f?.type === 'application/pdf' || f?.name?.endsWith('.pdf')) load(f);
});

function load(file) {
  pdfFile = file;
  document.getElementById('empty-state').classList.add('hidden');
  document.getElementById('file-ready').classList.remove('hidden');
  document.getElementById('file-name').textContent = file.name;
  document.getElementById('file-size').textContent = `${(file.size / 1024).toFixed(0)} KB`;
  document.getElementById('options-wrap').classList.remove('hidden');
  flattenBtn.disabled = false;
  statusMsg.textContent = 'Ready — click Flatten PDF.';
}

function reset() {
  pdfFile = null; fileInput.value = '';
  document.getElementById('empty-state').classList.remove('hidden');
  document.getElementById('file-ready').classList.add('hidden');
  document.getElementById('options-wrap').classList.add('hidden');
  flattenBtn.disabled = true;
  statusMsg.textContent = 'Upload a PDF with form fields to flatten.';
}

flattenBtn.addEventListener('click', async () => {
  const btn = flattenBtn;
  const label = document.getElementById('btn-label');
  const spinner = document.getElementById('spinner');
  btn.disabled = true; label.textContent = 'Flattening…'; spinner.classList.remove('hidden');
  statusMsg.textContent = 'Processing…';

  try {
    const buf = await pdfFile.arrayBuffer();
    const pdfDoc = await PDFDocument.load(buf, { ignoreEncryption: true });
    const form = pdfDoc.getForm();
    form.flatten();

    const out = await pdfDoc.save();
    const blob = new Blob([out], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const outName = pdfFile.name.replace(/\.pdf$/i, '-flattened.pdf');
    Object.assign(document.createElement('a'), { href: url, download: outName }).click();
    setTimeout(() => URL.revokeObjectURL(url), 15000);
    statusMsg.textContent = `Done — ${outName} downloaded (${(blob.size / 1024).toFixed(0)} KB).`;
  } catch (err) {
    console.error(err);
    statusMsg.textContent = 'Error: ' + err.message;
  } finally {
    btn.disabled = false; label.textContent = 'Flatten PDF'; spinner.classList.add('hidden');
  }
});

window.addEventListener('beforeunload', e => {
  if (pdfFile) { e.preventDefault(); e.returnValue = ''; }
});
</script>
