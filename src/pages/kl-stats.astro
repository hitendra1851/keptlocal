---
// Private analytics dashboard — noindex, excluded from sitemap
// URL: /kl-stats
//
// ONE-TIME SETUP (takes ~5 min):
//   1. Go to console.cloud.google.com
//      → APIs & Services → Library → search "Google Analytics Data API" → Enable
//   2. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
//      → Application type: Web application
//      → Authorized JavaScript origins: https://keptlocal.com  (add http://localhost:4321 for local)
//      → Copy the Client ID
//   3. Go to analytics.google.com → Admin → Property Settings
//      → Copy the numeric Property ID (e.g. 359123456) — NOT the Measurement ID G-XXXXXXXX
//   4. Paste both values into the CONFIG block in the <script> below
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Analytics · keptlocal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <script src="https://accounts.google.com/gsi/client" async></script>
  <style>
    :root {
      --paper: #faf8f3;
      --paper-dark: #f2efe6;
      --ink: #1a1815;
      --ink-soft: #3a3631;
      --ink-muted: #6b6660;
      --rule: #d9d4c5;
      --accent: #2d5016;
      --accent-soft: #4a7a2a;
      --accent-tint: #e6ede0;
      --danger: #9c2621;
      --danger-tint: #fef2f2;
      --font: "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
      --mono: ui-monospace, "SF Mono", Consolas, monospace;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      background: var(--paper);
      color: var(--ink);
      font-family: var(--font);
      font-size: 14px;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* Layout */
    .page { max-width: 1280px; margin: 0 auto; padding: 1.5rem 1.5rem 4rem; }
    .header {
      display: flex; align-items: center; justify-content: space-between;
      padding-bottom: 1.25rem; margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--rule);
    }
    .header-left { display: flex; align-items: center; gap: 0.625rem; }
    .header-logo {
      font-size: 1rem; font-weight: 600; color: var(--ink);
      display: flex; align-items: center; gap: 0.375rem;
    }
    .header-logo span { color: var(--accent); }
    .badge {
      font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em;
      padding: 0.2rem 0.5rem; border-radius: 999px;
      background: var(--accent-tint); color: var(--accent);
    }
    .header-meta { font-size: 0.75rem; color: var(--ink-muted); }

    /* Buttons */
    .btn {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.5rem 1rem; font-size: 0.825rem; font-weight: 500; font-family: var(--font);
      border-radius: 0.5rem; cursor: pointer; transition: all 0.15s; border: none;
      white-space: nowrap;
    }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-primary { background: var(--accent); color: #faf8f3; }
    .btn-primary:hover:not(:disabled) { background: var(--accent-soft); }
    .btn-ghost {
      background: transparent; color: var(--ink-soft);
      border: 1.5px solid var(--rule);
    }
    .btn-ghost:hover:not(:disabled) {
      border-color: var(--accent); color: var(--accent); background: var(--accent-tint);
    }

    /* Sign-in screen */
    #screen-signin {
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; min-height: 65vh; gap: 1.25rem; text-align: center;
    }
    #screen-signin .icon-wrap {
      width: 56px; height: 56px; border-radius: 50%;
      background: var(--accent-tint); display: flex; align-items: center; justify-content: center;
    }
    #screen-signin h2 { font-size: 1.125rem; font-weight: 600; color: var(--ink); }
    #screen-signin p { font-size: 0.85rem; color: var(--ink-muted); line-height: 1.6; max-width: 320px; }

    /* Setup notice */
    .notice {
      padding: 0.875rem 1rem; border-radius: 0.5rem; font-size: 0.825rem;
      line-height: 1.55; margin-bottom: 1.25rem;
    }
    .notice-warn { background: var(--accent-tint); border: 1px solid rgba(45,80,22,.2); color: var(--ink-soft); }
    .notice-error { background: var(--danger-tint); border: 1px solid #fecaca; color: var(--danger); }
    .notice code {
      font-family: var(--mono); font-size: 0.775rem;
      background: rgba(0,0,0,.06); padding: 0.1rem 0.3rem; border-radius: 3px;
    }

    /* Loading */
    #screen-loading {
      display: none; flex-direction: column; align-items: center;
      justify-content: center; min-height: 40vh; gap: 0.75rem;
      color: var(--ink-muted); font-size: 0.85rem;
    }
    .spinner {
      width: 28px; height: 28px;
      border: 2.5px solid var(--rule); border-top-color: var(--accent);
      border-radius: 50%; animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Dashboard */
    #screen-dashboard { display: none; }
    .toolbar {
      display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;
    }
    .toolbar-right { margin-left: auto; font-size: 0.75rem; color: var(--ink-muted); }

    /* Section label */
    .section-label {
      font-size: 0.675rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.09em; color: var(--ink-muted); margin-bottom: 0.75rem;
    }

    /* Stat cards */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.875rem; margin-bottom: 1.75rem;
    }
    @media (max-width: 900px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px) { .stats-grid { grid-template-columns: 1fr 1fr; } }

    .stat-card {
      background: var(--paper-dark); border: 1px solid var(--rule);
      border-radius: 0.75rem; padding: 1rem 1.125rem 1.125rem;
    }
    .stat-label { font-size: 0.72rem; color: var(--ink-muted); margin-bottom: 0.25rem; }
    .stat-value { font-size: 1.875rem; font-weight: 600; color: var(--ink); line-height: 1.1; }
    .stat-value.hi { color: var(--accent); }
    .stat-sub { font-size: 0.7rem; color: var(--ink-muted); margin-top: 0.3rem; }

    /* Data panels */
    .panels-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;
    }
    @media (max-width: 768px) { .panels-grid { grid-template-columns: 1fr; } }

    .panel {
      background: var(--paper-dark); border: 1px solid var(--rule);
      border-radius: 0.75rem; padding: 1.125rem;
    }
    .panel h3 {
      font-size: 0.675rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.09em; color: var(--ink-muted); margin-bottom: 1rem;
    }
    .panel-stack { display: flex; flex-direction: column; gap: 0.875rem; }

    /* Table */
    table { width: 100%; border-collapse: collapse; }
    thead th {
      font-size: 0.675rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.07em; color: var(--ink-muted);
      text-align: left; padding: 0 0 0.5rem; border-bottom: 1px solid var(--rule);
    }
    thead th:not(:first-child) { text-align: right; }
    tbody tr { border-bottom: 1px solid var(--rule); }
    tbody tr:last-child { border-bottom: none; }
    tbody td { padding: 0.5rem 0; color: var(--ink-soft); vertical-align: middle; }
    tbody td:not(:first-child) {
      text-align: right; color: var(--ink); font-weight: 500;
      font-variant-numeric: tabular-nums;
    }
    td.mono { font-family: var(--mono); font-size: 0.72rem; }
    td.truncate {
      max-width: 200px; overflow: hidden;
      text-overflow: ellipsis; white-space: nowrap;
    }

    /* Mini bar */
    .bar-wrap { display: flex; align-items: center; gap: 0.5rem; justify-content: flex-end; }
    .bar-track {
      width: 52px; height: 4px; background: rgba(45,80,22,.12);
      border-radius: 2px; flex-shrink: 0; overflow: hidden;
    }
    .bar-fill { height: 100%; background: var(--accent); border-radius: 2px; }

    /* Device row */
    .device-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.5rem 0; border-bottom: 1px solid var(--rule);
    }
    .device-row:last-child { border-bottom: none; }
    .device-label { color: var(--ink-soft); }
    .device-right { display: flex; align-items: center; gap: 0.875rem; }
    .device-sessions { font-weight: 500; font-variant-numeric: tabular-nums; color: var(--ink); }
    .device-bar-wrap { display: flex; align-items: center; gap: 0.4rem; }
    .device-pct { font-size: 0.72rem; color: var(--ink-muted); width: 34px; text-align: right; }
    .device-track { width: 60px; height: 4px; background: rgba(45,80,22,.12); border-radius: 2px; overflow: hidden; }
    .device-fill { height: 100%; background: var(--accent); border-radius: 2px; }
  </style>
</head>
<body>
<div class="page">

  <header class="header">
    <div class="header-left">
      <div class="header-logo">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        keptlocal <span>Analytics</span>
      </div>
      <span class="badge">Private</span>
    </div>
    <span class="header-meta" id="last-updated"></span>
  </header>

  <div id="notice-setup" class="notice notice-warn" style="display:none">
    <strong>Setup required.</strong> Open <code>src/pages/kl-stats.astro</code> and fill in
    <code>OAUTH_CLIENT_ID</code> and <code>GA4_PROPERTY_ID</code> in the CONFIG block.
    See the frontmatter comments for step-by-step instructions.
  </div>

  <div id="notice-error" class="notice notice-error" style="display:none"></div>

  <!-- Sign-in -->
  <div id="screen-signin">
    <div class="icon-wrap">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.75">
        <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <h2>keptlocal Analytics</h2>
    <p>Sign in with the Google account that has access to your GA4 property.</p>
    <button class="btn btn-primary" id="sign-in-btn" disabled>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0">
        <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/>
      </svg>
      Sign in with Google
    </button>
  </div>

  <!-- Loading -->
  <div id="screen-loading">
    <div class="spinner"></div>
    <span>Fetching analytics data…</span>
  </div>

  <!-- Dashboard -->
  <div id="screen-dashboard">
    <div class="toolbar">
      <button class="btn btn-ghost" id="refresh-btn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25">
          <path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Refresh
      </button>
      <a class="btn btn-ghost" href="https://analytics.google.com" target="_blank" rel="noopener">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Full GA4
      </a>
      <span class="toolbar-right" id="fetch-time"></span>
    </div>

    <p class="section-label">Overview</p>
    <div class="stats-grid" id="stats-grid"></div>

    <div class="panels-grid">
      <!-- Left: top pages -->
      <div class="panel">
        <h3>Top Pages · 30 days</h3>
        <table id="tbl-pages">
          <thead><tr><th>Page</th><th>Views</th><th>Users</th></tr></thead>
          <tbody></tbody>
        </table>
      </div>

      <!-- Right: countries + devices stacked -->
      <div class="panel-stack">
        <div class="panel">
          <h3>Countries · 30 days</h3>
          <table id="tbl-countries">
            <thead><tr><th>Country</th><th>Sessions</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
        <div class="panel">
          <h3>Devices · 30 days</h3>
          <div id="devices-list"></div>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
  // ╔═══════════════════════════════════════════════════════════════╗
  // ║  CONFIG — fill these two values, then deploy                  ║
  // ╚═══════════════════════════════════════════════════════════════╝
  const OAUTH_CLIENT_ID = '167546589966-doir8rkriihd8kirpm84t02lp6vnehq5.apps.googleusercontent.com';
  const GA4_PROPERTY_ID = '538937050';
  // ════════════════════════════════════════════════════════════════

  const configured =
    OAUTH_CLIENT_ID !== 'YOUR_OAUTH_CLIENT_ID_HERE' &&
    GA4_PROPERTY_ID !== 'YOUR_GA4_PROPERTY_ID_HERE';

  let tokenClient = null;
  let accessToken = null;

  if (!configured) {
    document.getElementById('notice-setup').style.display = 'block';
  }

  // GIS calls this when loaded
  window.onGoogleLibraryLoad = () => {
    if (!configured) return;
    tokenClient = window.google.accounts.oauth2.initTokenClient({
      client_id: OAUTH_CLIENT_ID,
      scope: 'https://www.googleapis.com/auth/analytics.readonly',
      callback: handleToken,
    });
    const btn = document.getElementById('sign-in-btn');
    btn.disabled = false;
    btn.addEventListener('click', () => tokenClient.requestAccessToken({ prompt: '' }));
  };

  document.getElementById('refresh-btn').addEventListener('click', fetchAll);

  function handleToken(resp) {
    if (resp.error) {
      if (resp.error === 'interaction_required' || resp.error === 'access_denied') {
        tokenClient.requestAccessToken({ prompt: 'consent' });
      } else {
        showError('OAuth: ' + resp.error);
      }
      return;
    }
    accessToken = resp.access_token;
    fetchAll();
  }

  async function ga(endpoint, body) {
    const res = await fetch(
      `https://analyticsdata.googleapis.com/v1beta/properties/${GA4_PROPERTY_ID}:${endpoint}`,
      {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      }
    );
    const json = await res.json();
    if (json.error) throw new Error(json.error.message || 'GA4 API error');
    return json;
  }

  async function fetchAll() {
    clearError();
    show('loading');
    try {
      const [rt, d0, d7, d30, pages, countries, devices] = await Promise.all([
        ga('runRealtimeReport', { metrics: [{ name: 'activeUsers' }] }),
        ga('runReport', {
          dateRanges: [{ startDate: 'today', endDate: 'today' }],
          metrics: metrics4(),
        }),
        ga('runReport', {
          dateRanges: [{ startDate: '7daysAgo', endDate: 'today' }],
          metrics: metrics4(),
        }),
        ga('runReport', {
          dateRanges: [{ startDate: '30daysAgo', endDate: 'today' }],
          metrics: [...metrics4(), { name: 'bounceRate' }],
        }),
        ga('runReport', {
          dateRanges: [{ startDate: '30daysAgo', endDate: 'today' }],
          dimensions: [{ name: 'pagePath' }],
          metrics: [{ name: 'screenPageViews' }, { name: 'activeUsers' }],
          orderBys: [{ metric: { metricName: 'screenPageViews' }, desc: true }],
          limit: 15,
        }),
        ga('runReport', {
          dateRanges: [{ startDate: '30daysAgo', endDate: 'today' }],
          dimensions: [{ name: 'country' }],
          metrics: [{ name: 'sessions' }],
          orderBys: [{ metric: { metricName: 'sessions' }, desc: true }],
          limit: 10,
        }),
        ga('runReport', {
          dateRanges: [{ startDate: '30daysAgo', endDate: 'today' }],
          dimensions: [{ name: 'deviceCategory' }],
          metrics: [{ name: 'sessions' }],
          orderBys: [{ metric: { metricName: 'sessions' }, desc: true }],
        }),
      ]);

      renderStats(rt, d0, d7, d30);
      renderPages(pages);
      renderCountries(countries);
      renderDevices(devices);

      const ts = new Date().toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
      document.getElementById('last-updated').textContent = `Updated ${ts}`;
      document.getElementById('fetch-time').textContent = `Fetched at ${ts}`;
      show('dashboard');
    } catch (err) {
      show('signin');
      showError(err.message);
    }
  }

  // ── helpers ──────────────────────────────────────────────────────

  function metrics4() {
    return [
      { name: 'screenPageViews' },
      { name: 'sessions' },
      { name: 'activeUsers' },
      { name: 'newUsers' },
    ];
  }

  function num(report, idx) {
    return parseInt(report?.rows?.[0]?.metricValues?.[idx]?.value ?? '0', 10);
  }

  function flt(report, idx) {
    return parseFloat(report?.rows?.[0]?.metricValues?.[idx]?.value ?? '0');
  }

  function f(n) {
    return Number(n).toLocaleString();
  }

  function show(screen) {
    document.getElementById('screen-signin').style.display = screen === 'signin' ? 'flex' : 'none';
    document.getElementById('screen-loading').style.display = screen === 'loading' ? 'flex' : 'none';
    document.getElementById('screen-dashboard').style.display = screen === 'dashboard' ? 'block' : 'none';
  }

  function showError(msg) {
    const el = document.getElementById('notice-error');
    el.textContent = 'Error: ' + msg;
    el.style.display = 'block';
  }

  function clearError() {
    document.getElementById('notice-error').style.display = 'none';
  }

  // ── render functions ─────────────────────────────────────────────

  function renderStats(rt, d0, d7, d30) {
    const activeNow = parseInt(rt?.rows?.[0]?.metricValues?.[0]?.value ?? '0', 10);
    const bounce = (flt(d30, 4) * 100).toFixed(1);

    const cards = [
      { label: 'Active now', val: f(activeNow), hi: true, sub: 'real-time' },
      { label: 'Views today', val: f(num(d0, 0)), sub: f(num(d0, 1)) + ' sessions' },
      { label: 'Views · 7 days', val: f(num(d7, 0)), sub: f(num(d7, 1)) + ' sessions' },
      { label: 'Views · 30 days', val: f(num(d30, 0)), sub: f(num(d30, 1)) + ' sessions' },
      { label: 'Users today', val: f(num(d0, 2)), sub: f(num(d0, 3)) + ' new' },
      { label: 'Users · 7 days', val: f(num(d7, 2)), sub: f(num(d7, 3)) + ' new' },
      { label: 'Users · 30 days', val: f(num(d30, 2)), sub: f(num(d30, 3)) + ' new' },
      { label: 'Bounce · 30 days', val: bounce + '%', sub: 'lower is better' },
    ];

    document.getElementById('stats-grid').innerHTML = cards.map(c => `
      <div class="stat-card">
        <div class="stat-label">${c.label}</div>
        <div class="stat-value${c.hi ? ' hi' : ''}">${c.val}</div>
        <div class="stat-sub">${c.sub}</div>
      </div>
    `).join('');
  }

  function renderPages(data) {
    if (!data.rows?.length) return;
    const max = parseInt(data.rows[0].metricValues[0].value, 10);
    document.querySelector('#tbl-pages tbody').innerHTML = data.rows.map(row => {
      const path = row.dimensionValues[0].value;
      const views = parseInt(row.metricValues[0].value, 10);
      const users = parseInt(row.metricValues[1].value, 10);
      const pct = Math.round((views / max) * 100);
      return `<tr>
        <td class="mono truncate" title="${path}">${path}</td>
        <td><div class="bar-wrap">${f(views)}<div class="bar-track"><div class="bar-fill" style="width:${pct}%"></div></div></div></td>
        <td>${f(users)}</td>
      </tr>`;
    }).join('');
  }

  function renderCountries(data) {
    if (!data.rows?.length) return;
    const max = parseInt(data.rows[0].metricValues[0].value, 10);
    document.querySelector('#tbl-countries tbody').innerHTML = data.rows.map(row => {
      const country = row.dimensionValues[0].value;
      const sessions = parseInt(row.metricValues[0].value, 10);
      const pct = Math.round((sessions / max) * 100);
      return `<tr>
        <td>${country}</td>
        <td><div class="bar-wrap">${f(sessions)}<div class="bar-track"><div class="bar-fill" style="width:${pct}%"></div></div></div></td>
      </tr>`;
    }).join('');
  }

  function renderDevices(data) {
    if (!data.rows?.length) return;
    const total = data.rows.reduce((s, r) => s + parseInt(r.metricValues[0].value, 10), 0);
    document.getElementById('devices-list').innerHTML = data.rows.map(row => {
      const device = row.dimensionValues[0].value;
      const sessions = parseInt(row.metricValues[0].value, 10);
      const pct = ((sessions / total) * 100).toFixed(1);
      const label = device.charAt(0).toUpperCase() + device.slice(1);
      return `<div class="device-row">
        <span class="device-label">${label}</span>
        <div class="device-right">
          <span class="device-sessions">${f(sessions)}</span>
          <div class="device-bar-wrap">
            <span class="device-pct">${pct}%</span>
            <div class="device-track"><div class="device-fill" style="width:${pct}%"></div></div>
          </div>
        </div>
      </div>`;
    }).join('');
  }
</script>
</body>
</html>
