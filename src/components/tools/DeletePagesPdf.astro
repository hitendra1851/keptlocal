---
---

<div id="delete-pages-app" class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]">
  <!-- Drop zone -->
  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" accept="application/pdf,.pdf" class="hidden" />
    <div id="empty-state">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop a PDF here, or</p>
      <button type="button" id="browse-btn" class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">
        choose a file from your device
      </button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">Files never leave your browser.</p>
    </div>
  </div>

  <!-- Controls (shown after file loaded) -->
  <div id="controls" class="hidden px-4 pb-4 space-y-4">
    <div class="flex items-center gap-3 p-3 bg-[var(--color-paper-dark)] rounded-lg border border-[var(--color-rule)]">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-accent)] shrink-0">
        <path d="M9 12h6m-6 4h6m-7-8h.01M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <div class="flex-1 min-w-0">
        <div id="file-name" class="text-sm text-[var(--color-ink)] truncate"></div>
        <div id="file-info" class="text-xs text-[var(--color-ink-muted)]"></div>
      </div>
      <button type="button" id="clear-btn" class="text-xs text-[var(--color-ink-muted)] hover:text-[var(--color-warn)] shrink-0">Remove</button>
    </div>

    <div>
      <label for="pages-input" class="block text-sm font-medium text-[var(--color-ink)] mb-1">
        Pages to delete
      </label>
      <input
        type="text"
        id="pages-input"
        placeholder="e.g. 1, 3, 5-8"
        class="w-full px-3 py-2 text-sm rounded-md border border-[var(--color-rule)] bg-[var(--color-paper)] text-[var(--color-ink)] focus:outline-none focus:border-[var(--color-accent)]"
      />
      <p class="text-xs text-[var(--color-ink-muted)] mt-1">Comma-separated page numbers and ranges. Pages are numbered from 1.</p>
    </div>
  </div>

  <!-- Action bar -->
  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <div id="status-msg" class="text-sm text-[var(--color-ink-muted)] min-h-[1.25rem]">
      Drop a PDF to get started.
    </div>
    <button type="button" id="process-btn" class="btn-primary" disabled>
      <span id="btn-label">Delete pages & download</span>
      <svg id="spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12a9 9 0 11-6.219-8.56" />
      </svg>
    </button>
  </div>
</div>

<script type="module">
  import { PDFDocument } from "https://esm.sh/pdf-lib@1.17.1";

  let pdfBytes = null;
  let pageCount = 0;
  let processing = false;

  const $ = (id) => document.getElementById(id);
  const dropZone = $("drop-zone");
  const fileInput = $("file-input");
  const emptyState = $("empty-state");
  const controls = $("controls");
  const fileName = $("file-name");
  const fileInfo = $("file-info");
  const pagesInput = $("pages-input");
  const processBtn = $("process-btn");
  const btnLabel = $("btn-label");
  const spinner = $("spinner");
  const statusMsg = $("status-msg");

  const fmtSize = (b) => b < 1024 * 1024 ? `${(b / 1024).toFixed(1)} KB` : `${(b / 1024 / 1024).toFixed(1)} MB`;
  const setStatus = (msg, err = false) => {
    statusMsg.textContent = msg;
    statusMsg.style.color = err ? "var(--color-warn)" : "";
  };

  const parsePages = (input, total) => {
    const pages = new Set();
    for (const part of input.split(",")) {
      const trimmed = part.trim();
      const range = trimmed.match(/^(\d+)\s*-\s*(\d+)$/);
      if (range) {
        const from = parseInt(range[1]);
        const to = parseInt(range[2]);
        if (from < 1 || to > total || from > to) return null;
        for (let i = from; i <= to; i++) pages.add(i);
      } else {
        const n = parseInt(trimmed);
        if (isNaN(n) || n < 1 || n > total) return null;
        pages.add(n);
      }
    }
    return pages;
  };

  const loadFile = async (file) => {
    if (!file.name.toLowerCase().endsWith(".pdf") && file.type !== "application/pdf") {
      setStatus("Only PDF files are accepted.", true);
      return;
    }
    pdfBytes = await file.arrayBuffer();
    const doc = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
    pageCount = doc.getPageCount();
    fileName.textContent = file.name;
    fileInfo.textContent = `${pageCount} pages · ${fmtSize(file.size)}`;
    emptyState.classList.add("hidden");
    controls.classList.remove("hidden");
    processBtn.disabled = false;
    setStatus(`Loaded. Enter page numbers to delete (1–${pageCount}).`);
  };

  $("browse-btn").addEventListener("click", () => fileInput.click());
  dropZone.addEventListener("click", (e) => { if (e.target === dropZone || e.target === emptyState) fileInput.click(); });
  fileInput.addEventListener("change", (e) => { if (e.target.files[0]) loadFile(e.target.files[0]); fileInput.value = ""; });

  ["dragenter", "dragover"].forEach((ev) => dropZone.addEventListener(ev, (e) => { e.preventDefault(); dropZone.classList.add("dragging"); }));
  ["dragleave", "drop"].forEach((ev) => dropZone.addEventListener(ev, (e) => { e.preventDefault(); dropZone.classList.remove("dragging"); }));
  dropZone.addEventListener("drop", (e) => { if (e.dataTransfer?.files[0]) loadFile(e.dataTransfer.files[0]); });

  $("clear-btn").addEventListener("click", () => {
    pdfBytes = null; pageCount = 0;
    emptyState.classList.remove("hidden");
    controls.classList.add("hidden");
    processBtn.disabled = true;
    pagesInput.value = "";
    setStatus("Drop a PDF to get started.");
  });

  processBtn.addEventListener("click", async () => {
    if (!pdfBytes || processing) return;
    const raw = pagesInput.value.trim();
    if (!raw) { setStatus("Enter at least one page number to delete.", true); return; }

    const toDelete = parsePages(raw, pageCount);
    if (!toDelete) { setStatus(`Invalid page range. Use numbers between 1 and ${pageCount}.`, true); return; }
    if (toDelete.size >= pageCount) { setStatus("You must keep at least one page in the PDF.", true); return; }

    processing = true;
    processBtn.disabled = true;
    spinner.classList.remove("hidden");
    btnLabel.textContent = "Processing...";
    setStatus("Removing pages in your browser...");

    try {
      const doc = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      // Remove in reverse order so indices stay valid
      const indicesToRemove = [...toDelete].map((p) => p - 1).sort((a, b) => b - a);
      for (const idx of indicesToRemove) doc.removePage(idx);

      const out = await doc.save();
      const blob = new Blob([out], { type: "application/pdf" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = `pages-deleted-${new Date().toISOString().slice(0, 10)}.pdf`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);

      const remaining = pageCount - toDelete.size;
      setStatus(`Done. Downloaded PDF with ${remaining} page${remaining !== 1 ? "s" : ""} (removed ${toDelete.size}).`);
    } catch (err) {
      console.error(err);
      setStatus(`Error: ${err?.message || "could not process the PDF."}`, true);
    } finally {
      processing = false;
      spinner.classList.add("hidden");
      btnLabel.textContent = "Delete pages & download";
      processBtn.disabled = false;
    }
  });

  window.addEventListener("beforeunload", (e) => { if (processing) { e.preventDefault(); e.returnValue = ""; } });
</script>
