---
// PDF to JPG — renders PDF pages via pdf.js + Canvas API, bundles output via JSZip
---

<div
  id="pdf-to-jpg-app"
  class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]"
>
  <!-- Drop zone -->
  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" accept="application/pdf,.pdf" class="hidden" />

    <div id="empty-state">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop a PDF here, or</p>
      <button type="button" id="browse-btn" class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">
        choose a file from your device
      </button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">One PDF at a time. Files never leave your browser.</p>
    </div>
  </div>

  <!-- File loaded state -->
  <div id="file-loaded" class="hidden px-4 pb-4">
    <!-- File info bar -->
    <div class="flex items-center gap-3 px-3 py-2.5 bg-[var(--color-paper-dark)] rounded-md mb-5">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-accent)] shrink-0">
        <path d="M9 12h6m-6 4h6m-7-8h.01M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <div class="flex-1 min-w-0">
        <div id="file-name" class="text-sm text-[var(--color-ink)] truncate"></div>
        <div id="file-meta" class="text-xs text-[var(--color-ink-muted)]"></div>
      </div>
      <button type="button" id="change-file-btn" class="text-xs text-[var(--color-ink-muted)] hover:text-[var(--color-accent)] shrink-0">
        Change file
      </button>
    </div>

    <!-- Quality picker -->
    <p class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] font-medium mb-2">Output quality</p>
    <div class="flex gap-2 mb-1">
      <button type="button" data-scale="1.5" class="quality-btn flex-1 py-2.5 px-3 rounded-lg border text-sm text-center transition-colors">
        <div class="font-medium">Standard</div>
        <div class="text-xs opacity-70 mt-0.5">~1200 px wide</div>
      </button>
      <button type="button" data-scale="2.0" class="quality-btn flex-1 py-2.5 px-3 rounded-lg border text-sm text-center transition-colors">
        <div class="font-medium">High</div>
        <div class="text-xs opacity-70 mt-0.5">~1700 px wide</div>
      </button>
      <button type="button" data-scale="3.0" class="quality-btn flex-1 py-2.5 px-3 rounded-lg border text-sm text-center transition-colors">
        <div class="font-medium">Best</div>
        <div class="text-xs opacity-70 mt-0.5">~2500 px wide</div>
      </button>
    </div>
    <p class="text-xs text-[var(--color-ink-muted)] mb-1">
      For just some pages, use <a href="/tools/split-pdf" class="text-[var(--color-accent)] underline-offset-2 underline hover:no-underline">Split PDF</a> first.
    </p>
  </div>

  <!-- Action bar -->
  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <div id="status-msg" class="text-sm text-[var(--color-ink-muted)] min-h-[1.25rem]">
      Upload a PDF to get started.
    </div>
    <button type="button" id="convert-btn" class="btn-primary" disabled>
      <span id="convert-label">Convert & download</span>
      <svg id="spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12a9 9 0 11-6.219-8.56" />
      </svg>
    </button>
  </div>
</div>

<script type="module">
  import * as pdfjs from 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.4.168/build/pdf.min.mjs';
  import JSZip from 'https://esm.sh/jszip@3.10.1';

  pdfjs.GlobalWorkerOptions.workerSrc =
    'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.4.168/build/pdf.worker.min.mjs';

  let pdfBytes = null;
  let pageCount = 0;
  let fileName = '';
  let scale = 2.0;
  let processing = false;

  const $ = (id) => document.getElementById(id);

  const dropZone   = $('drop-zone');
  const fileInput  = $('file-input');
  const browseBtn  = $('browse-btn');
  const emptyState = $('empty-state');
  const fileLoaded = $('file-loaded');
  const fileNameEl = $('file-name');
  const fileMeta   = $('file-meta');
  const changeFileBtn = $('change-file-btn');
  const convertBtn = $('convert-btn');
  const convertLabel = $('convert-label');
  const spinner    = $('spinner');
  const statusMsg  = $('status-msg');

  const fmtSize = (b) =>
    b < 1024 * 1024 ? `${(b / 1024).toFixed(1)} KB` : `${(b / 1024 / 1024).toFixed(1)} MB`;

  const setStatus = (msg, isError = false) => {
    statusMsg.textContent = msg;
    statusMsg.style.color = isError ? 'var(--color-warn)' : '';
  };

  // Quality buttons
  const qualityBtns = document.querySelectorAll('.quality-btn');
  const setScale = (s) => {
    scale = s;
    qualityBtns.forEach((btn) => {
      const active = parseFloat(btn.dataset.scale) === s;
      btn.classList.toggle('border-[var(--color-accent)]', active);
      btn.classList.toggle('bg-[var(--color-accent-tint)]', active);
      btn.classList.toggle('text-[var(--color-accent)]', active);
      btn.classList.toggle('border-[var(--color-rule)]', !active);
      btn.classList.toggle('text-[var(--color-ink-soft)]', !active);
    });
  };
  qualityBtns.forEach((btn) =>
    btn.addEventListener('click', () => setScale(parseFloat(btn.dataset.scale)))
  );
  setScale(2.0);

  // Load file
  const loadFile = async (file) => {
    if (!file || !(file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf'))) {
      setStatus('Only PDF files are accepted.', true);
      return;
    }
    pdfBytes = await file.arrayBuffer();
    fileName = file.name.replace(/\.pdf$/i, '');
    try {
      const doc = await pdfjs.getDocument({ data: pdfBytes.slice(0) }).promise;
      pageCount = doc.getPageCount();
      doc.destroy();
    } catch {
      setStatus('Could not read the PDF — check that the file is valid.', true);
      pdfBytes = null;
      return;
    }
    fileNameEl.textContent = file.name;
    fileMeta.textContent = `${pageCount} page${pageCount !== 1 ? 's' : ''} · ${fmtSize(file.size)}`;
    emptyState.classList.add('hidden');
    fileLoaded.classList.remove('hidden');
    convertBtn.disabled = false;
    setStatus(`Ready — will convert ${pageCount} page${pageCount !== 1 ? 's' : ''} to JPG.`);
  };

  const reset = () => {
    pdfBytes = null; pageCount = 0; fileName = '';
    emptyState.classList.remove('hidden');
    fileLoaded.classList.add('hidden');
    convertBtn.disabled = true;
    setStatus('Upload a PDF to get started.');
  };

  // Render one page to JPEG blob
  const renderPage = async (pdfDoc, pageNum) => {
    const page = await pdfDoc.getPage(pageNum);
    const viewport = page.getViewport({ scale });
    const canvas = document.createElement('canvas');
    canvas.width  = Math.round(viewport.width);
    canvas.height = Math.round(viewport.height);
    const ctx = canvas.getContext('2d');
    await page.render({ canvasContext: ctx, viewport }).promise;
    return new Promise((resolve) => canvas.toBlob(resolve, 'image/jpeg', 0.92));
  };

  const triggerDownload = (blob, name) => {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = name;
    document.body.appendChild(a); a.click(); a.remove();
    URL.revokeObjectURL(url);
  };

  // Drop zone events
  browseBtn?.addEventListener('click', () => fileInput.click());
  changeFileBtn?.addEventListener('click', () => { reset(); fileInput.click(); });
  fileInput.addEventListener('change', (e) => {
    if (e.target.files?.[0]) loadFile(e.target.files[0]);
    fileInput.value = '';
  });
  ['dragenter', 'dragover'].forEach((ev) =>
    dropZone.addEventListener(ev, (e) => { e.preventDefault(); dropZone.classList.add('dragging'); })
  );
  ['dragleave', 'drop'].forEach((ev) =>
    dropZone.addEventListener(ev, (e) => { e.preventDefault(); dropZone.classList.remove('dragging'); })
  );
  dropZone.addEventListener('drop', (e) => {
    if (e.dataTransfer?.files?.[0]) loadFile(e.dataTransfer.files[0]);
  });
  dropZone.addEventListener('click', (e) => {
    if (e.target === dropZone || e.target === emptyState) fileInput.click();
  });

  // Convert
  convertBtn.addEventListener('click', async () => {
    if (!pdfBytes || processing) return;
    processing = true;
    convertBtn.disabled = true;
    spinner.classList.remove('hidden');
    convertLabel.textContent = 'Converting…';

    try {
      const pdfDoc = await pdfjs.getDocument({ data: pdfBytes.slice(0) }).promise;
      const total = pdfDoc.numPages;
      const padLen = String(total).length;

      if (total === 1) {
        setStatus('Rendering page 1…');
        const blob = await renderPage(pdfDoc, 1);
        triggerDownload(blob, `${fileName}.jpg`);
        setStatus('✓ Downloaded 1 JPG.');
      } else {
        const zip = new JSZip();
        for (let i = 1; i <= total; i++) {
          setStatus(`Rendering page ${i} of ${total}…`);
          const blob = await renderPage(pdfDoc, i);
          const arrBuf = await blob.arrayBuffer();
          zip.file(`${fileName}-page-${String(i).padStart(padLen, '0')}.jpg`, arrBuf);
        }
        setStatus('Compressing ZIP…');
        const zipBlob = await zip.generateAsync({ type: 'blob' });
        triggerDownload(zipBlob, `${fileName}-jpg.zip`);
        setStatus(`✓ Downloaded ZIP with ${total} JPGs.`);
      }
      pdfDoc.destroy();
    } catch (err) {
      console.error(err);
      setStatus(`Error: ${err?.message || 'conversion failed — check the file is a valid PDF.'}`, true);
    } finally {
      processing = false;
      spinner.classList.add('hidden');
      convertLabel.textContent = 'Convert & download';
      convertBtn.disabled = false;
    }
  });

  window.addEventListener('beforeunload', (e) => {
    if (processing) { e.preventDefault(); e.returnValue = ''; }
  });
</script>
