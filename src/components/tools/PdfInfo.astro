---
// PDF Info Viewer — reads metadata via pdf-lib, display-only, nothing uploaded
---

<div
  id="pdf-info-app"
  class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]"
>
  <!-- Drop zone -->
  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" accept="application/pdf,.pdf" class="hidden" />
    <div id="empty-state">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop a PDF here, or</p>
      <button type="button" id="browse-btn" class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">
        choose a file from your device
      </button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">Files never leave your browser.</p>
    </div>
  </div>

  <!-- Results -->
  <div id="results" class="hidden px-4 pb-4">
    <!-- Header row -->
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2.5">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-accent)]">
          <path d="M9 12h6m-6 4h6m-7-8h.01M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span id="result-filename" class="text-sm font-medium text-[var(--color-ink)] truncate max-w-xs"></span>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <button type="button" id="copy-btn" class="text-xs px-2.5 py-1.5 rounded-md border border-[var(--color-rule)] text-[var(--color-ink-soft)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors">
          Copy
        </button>
        <button type="button" id="change-file-btn" class="text-xs text-[var(--color-ink-muted)] hover:text-[var(--color-accent)]">
          Change file
        </button>
      </div>
    </div>

    <!-- Info sections -->
    <div class="space-y-4">
      <!-- File -->
      <div>
        <p class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] font-medium mb-2">File</p>
        <dl id="section-file" class="info-grid"></dl>
      </div>
      <!-- Pages -->
      <div>
        <p class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] font-medium mb-2">Pages</p>
        <dl id="section-pages" class="info-grid"></dl>
      </div>
      <!-- Metadata -->
      <div id="meta-section">
        <p class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] font-medium mb-2">Metadata</p>
        <dl id="section-meta" class="info-grid"></dl>
      </div>
    </div>
  </div>

  <!-- Status bar -->
  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)]">
    <div id="status-msg" class="text-sm text-[var(--color-ink-muted)]">Upload a PDF to inspect it.</div>
  </div>
</div>

<style>
  .info-grid {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0;
    border: 1px solid var(--color-rule);
    border-radius: 0.5rem;
    overflow: hidden;
    font-size: 0.8125rem;
  }
  .info-grid dt {
    padding: 0.5rem 0.75rem;
    background: var(--color-paper-dark);
    color: var(--color-ink-muted);
    font-weight: 500;
    border-bottom: 1px solid var(--color-rule);
  }
  .info-grid dd {
    padding: 0.5rem 0.75rem;
    color: var(--color-ink-soft);
    border-bottom: 1px solid var(--color-rule);
    word-break: break-word;
  }
  .info-grid dt:last-of-type,
  .info-grid dd:last-child {
    border-bottom: none;
  }
</style>

<script type="module">
  import { PDFDocument } from 'https://esm.sh/pdf-lib@1.17.1';

  const $ = (id) => document.getElementById(id);

  const dropZone     = $('drop-zone');
  const fileInput    = $('file-input');
  const browseBtn    = $('browse-btn');
  const emptyState   = $('empty-state');
  const results      = $('results');
  const resultFilename = $('result-filename');
  const changeFileBtn  = $('change-file-btn');
  const copyBtn        = $('copy-btn');
  const statusMsg      = $('status-msg');
  const sectionFile    = $('section-file');
  const sectionPages   = $('section-pages');
  const sectionMeta    = $('section-meta');

  const setStatus = (msg, isError = false) => {
    statusMsg.textContent = msg;
    statusMsg.style.color = isError ? 'var(--color-warn)' : '';
  };

  const fmtSize = (b) => {
    if (b < 1024) return `${b} B`;
    if (b < 1024 * 1024) return `${(b / 1024).toFixed(1)} KB`;
    return `${(b / 1024 / 1024).toFixed(2)} MB`;
  };

  const fmtPts = (pts) => {
    const mm   = (pts * 25.4 / 72).toFixed(1);
    const inch = (pts / 72).toFixed(2);
    return `${pts.toFixed(0)} pt  (${mm} mm / ${inch} in)`;
  };

  const fmtDate = (d) => {
    if (!d) return null;
    try { return new Intl.DateTimeFormat(undefined, { dateStyle: 'medium', timeStyle: 'short' }).format(d); }
    catch { return String(d); }
  };

  const readPdfVersion = (bytes) => {
    // First 8 bytes: %PDF-X.Y
    const header = new TextDecoder().decode(new Uint8Array(bytes, 0, 10));
    const m = header.match(/%PDF-(\d+\.\d+)/);
    return m ? m[1] : 'Unknown';
  };

  const buildDl = (el, rows) => {
    el.innerHTML = rows
      .map(([label, value]) =>
        `<dt>${label}</dt><dd>${value ?? '<span class="opacity-40 italic">not set</span>'}</dd>`
      )
      .join('');
  };

  let copyText = '';

  const loadFile = async (file) => {
    if (!file || !(file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf'))) {
      setStatus('Only PDF files are accepted.', true);
      return;
    }
    setStatus('Reading…');
    const bytes = await file.arrayBuffer();

    let doc;
    try {
      doc = await PDFDocument.load(bytes, { ignoreEncryption: true });
    } catch (err) {
      setStatus(`Could not read PDF: ${err?.message || 'invalid file.'}`, true);
      return;
    }

    const version  = readPdfVersion(bytes);
    const pages    = doc.getPageCount();
    const title    = doc.getTitle()    || null;
    const author   = doc.getAuthor()   || null;
    const subject  = doc.getSubject()  || null;
    const creator  = doc.getCreator()  || null;
    const producer = doc.getProducer() || null;
    const created  = fmtDate(doc.getCreationDate());
    const modified = fmtDate(doc.getModificationDate());

    // Page sizes
    const sizeMap = new Map();
    for (let i = 0; i < pages; i++) {
      const { width, height } = doc.getPage(i).getSize();
      const key = `${width.toFixed(1)}×${height.toFixed(1)}`;
      sizeMap.set(key, { width, height, count: (sizeMap.get(key)?.count ?? 0) + 1 });
    }
    const sizeEntries = [...sizeMap.values()];
    const pageSizeStr = sizeEntries.length === 1
      ? `${fmtPts(sizeEntries[0].width)} × ${fmtPts(sizeEntries[0].height)}`
      : sizeEntries.map((s) => `${fmtPts(s.width)} × ${fmtPts(s.height)} (${s.count} page${s.count !== 1 ? 's' : ''})`).join('\n');

    const orientations = sizeEntries.map((s) =>
      s.width > s.height ? 'Landscape' : s.width < s.height ? 'Portrait' : 'Square'
    );
    const orientation = [...new Set(orientations)].join(' / ');

    // Render
    resultFilename.textContent = file.name;
    emptyState.classList.add('hidden');
    results.classList.remove('hidden');

    buildDl(sectionFile, [
      ['File name', file.name],
      ['File size', fmtSize(file.size)],
      ['PDF version', version],
    ]);

    buildDl(sectionPages, [
      ['Page count', String(pages)],
      ['Orientation', orientation],
      ['Page size', pageSizeStr.replace(/\n/g, '<br>')],
    ]);

    buildDl(sectionMeta, [
      ['Title', title],
      ['Author', author],
      ['Subject', subject],
      ['Creator', creator],
      ['Producer', producer],
      ['Created', created],
      ['Modified', modified],
    ]);

    // Build copy text
    copyText = [
      `File: ${file.name}`,
      `Size: ${fmtSize(file.size)}`,
      `PDF version: ${version}`,
      `Pages: ${pages}`,
      `Orientation: ${orientation}`,
      `Page size: ${pageSizeStr}`,
      title    ? `Title: ${title}`       : null,
      author   ? `Author: ${author}`     : null,
      subject  ? `Subject: ${subject}`   : null,
      creator  ? `Creator: ${creator}`   : null,
      producer ? `Producer: ${producer}` : null,
      created  ? `Created: ${created}`   : null,
      modified ? `Modified: ${modified}` : null,
    ].filter(Boolean).join('\n');

    setStatus(`Done — ${pages} page${pages !== 1 ? 's' : ''}, PDF ${version}, ${fmtSize(file.size)}.`);
  };

  const reset = () => {
    emptyState.classList.remove('hidden');
    results.classList.add('hidden');
    copyText = '';
    setStatus('Upload a PDF to inspect it.');
  };

  // Copy to clipboard
  copyBtn?.addEventListener('click', async () => {
    if (!copyText) return;
    try {
      await navigator.clipboard.writeText(copyText);
      copyBtn.textContent = 'Copied!';
      setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
    } catch {
      copyBtn.textContent = 'Failed';
      setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
    }
  });

  // File events
  browseBtn?.addEventListener('click', () => fileInput.click());
  changeFileBtn?.addEventListener('click', () => { reset(); fileInput.click(); });
  fileInput.addEventListener('change', (e) => {
    if (e.target.files?.[0]) loadFile(e.target.files[0]);
    fileInput.value = '';
  });
  ['dragenter', 'dragover'].forEach((ev) =>
    dropZone.addEventListener(ev, (e) => { e.preventDefault(); dropZone.classList.add('dragging'); })
  );
  ['dragleave', 'drop'].forEach((ev) =>
    dropZone.addEventListener(ev, (e) => { e.preventDefault(); dropZone.classList.remove('dragging'); })
  );
  dropZone.addEventListener('drop', (e) => {
    if (e.dataTransfer?.files?.[0]) loadFile(e.dataTransfer.files[0]);
  });
  dropZone.addEventListener('click', (e) => {
    if (e.target === dropZone || e.target === emptyState) fileInput.click();
  });
</script>
