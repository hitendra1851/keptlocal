---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-rule)] mt-24 bg-[var(--color-paper)]">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-3">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-[var(--color-accent)]">
            <rect x="4" y="11" width="16" height="10" rx="2" stroke="currentColor" stroke-width="1.75" />
            <path d="M8 11V7a4 4 0 118 0v4" stroke="currentColor" stroke-width="1.75" />
            <circle cx="12" cy="16" r="1.25" fill="currentColor" />
          </svg>
          <span class="font-display text-xl">
            kept<span class="text-[var(--color-accent)]">local</span>
          </span>
        </div>
        <p class="text-sm text-[var(--color-ink-muted)] leading-relaxed max-w-xs">
          Browser-only file tools. No uploads, no accounts, no tracking.
        </p>
      </div>

      <div>
        <h4 class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] mb-3 font-medium">PDF Tools</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/tools/merge-pdf"      class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Merge PDF</a></li>
          <li><a href="/tools/split-pdf"      class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Split PDF</a></li>
          <li><a href="/tools/pdf-to-jpg"     class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">PDF to JPG</a></li>
          <li><a href="/tools/jpg-to-pdf"     class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">JPG to PDF</a></li>
          <li><a href="/tools/rotate-pdf"     class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Rotate PDF</a></li>
          <li><a href="/tools/reorder-pdf"    class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Reorder Pages</a></li>
          <li><a href="/tools/watermark-pdf"  class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Watermark PDF</a></li>
          <li><a href="/tools/pdf-page-count" class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">PDF Info</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] mb-3 font-medium">Image Tools</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/tools/compress-image" class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Compress Image</a></li>
          <li><a href="/tools/resize-image"   class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Resize Image</a></li>
          <li><a href="/tools/convert-image"  class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Convert Image</a></li>
          <li><a href="/tools/crop-image"     class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Crop Image</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] mb-3 font-medium">Site</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/tools"   class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">All Tools</a></li>
          <li><a href="/blog"    class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Blog</a></li>
          <li><a href="/about"   class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">About</a></li>
          <li><a href="/privacy" class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Privacy</a></li>
          <li><a href="/terms"   class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Terms</a></li>
          <li><a href="/contact" class="text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[var(--color-rule)] pt-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
      <p class="text-xs text-[var(--color-ink-muted)]">
        © {year} keptlocal. Built quietly.
      </p>
      <p class="text-xs text-[var(--color-ink-muted)]">
        All processing happens in your browser.
      </p>
    </div>
  </div>
</footer>
