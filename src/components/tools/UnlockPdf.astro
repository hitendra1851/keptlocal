---
---

<div id="unlock-pdf-app" class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]">
  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" accept="application/pdf,.pdf" class="hidden" />
    <div id="empty-state">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop a password-protected PDF here, or</p>
      <button type="button" id="browse-btn" class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">choose a file from your device</button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">Files never leave your browser.</p>
    </div>
  </div>

  <div id="controls" class="hidden px-4 pb-4 space-y-4">
    <div class="flex items-center gap-3 p-3 bg-[var(--color-paper-dark)] rounded-lg border border-[var(--color-rule)]">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-accent)] shrink-0">
        <path d="M9 12h6m-6 4h6m-7-8h.01M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <div class="flex-1 min-w-0">
        <div id="file-name" class="text-sm text-[var(--color-ink)] truncate"></div>
        <div id="file-size" class="text-xs text-[var(--color-ink-muted)]"></div>
      </div>
      <button type="button" id="clear-btn" class="text-xs text-[var(--color-ink-muted)] hover:text-[var(--color-warn)] shrink-0">Remove</button>
    </div>

    <div>
      <label for="password-input" class="block text-sm font-medium text-[var(--color-ink)] mb-1">PDF password</label>
      <input type="password" id="password-input" placeholder="Enter the PDF password"
        class="w-full px-3 py-2 text-sm rounded-md border border-[var(--color-rule)] bg-[var(--color-paper)] text-[var(--color-ink)] focus:outline-none focus:border-[var(--color-accent)]"
      />
    </div>
  </div>

  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <div id="status-msg" class="text-sm text-[var(--color-ink-muted)] min-h-[1.25rem]">Drop a password-protected PDF to get started.</div>
    <button type="button" id="process-btn" class="btn-primary" disabled>
      <span id="btn-label">Unlock & download</span>
      <svg id="spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56" /></svg>
    </button>
  </div>
</div>

<script type="module">
  import { PDFDocument } from "https://esm.sh/pdf-lib@1.17.1";

  let pdfBytes = null;
  let processing = false;
  const $ = (id) => document.getElementById(id);
  const fmtSize = (b) => b < 1048576 ? `${(b/1024).toFixed(1)} KB` : `${(b/1048576).toFixed(1)} MB`;
  const setStatus = (msg, err=false) => { $("status-msg").textContent = msg; $("status-msg").style.color = err ? "var(--color-warn)" : ""; };

  const loadFile = async (file) => {
    if (!file.name.toLowerCase().endsWith(".pdf") && file.type !== "application/pdf") { setStatus("Only PDF files are accepted.", true); return; }
    pdfBytes = await file.arrayBuffer();
    $("file-name").textContent = file.name;
    $("file-size").textContent = fmtSize(file.size);
    $("empty-state").classList.add("hidden");
    $("controls").classList.remove("hidden");
    $("process-btn").disabled = false;
    setStatus("Enter the PDF password and click Unlock.");
  };

  $("browse-btn").addEventListener("click", () => $("file-input").click());
  $("drop-zone").addEventListener("click", (e) => { if (e.target === $("drop-zone") || e.target === $("empty-state")) $("file-input").click(); });
  $("file-input").addEventListener("change", (e) => { if (e.target.files[0]) loadFile(e.target.files[0]); $("file-input").value = ""; });
  const dz = $("drop-zone");
  ["dragenter","dragover"].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.add("dragging"); }));
  ["dragleave","drop"].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.remove("dragging"); }));
  dz.addEventListener("drop", e => { if (e.dataTransfer?.files[0]) loadFile(e.dataTransfer.files[0]); });

  $("clear-btn").addEventListener("click", () => {
    pdfBytes = null;
    $("empty-state").classList.remove("hidden"); $("controls").classList.add("hidden");
    $("process-btn").disabled = true; $("password-input").value = "";
    setStatus("Drop a password-protected PDF to get started.");
  });

  $("process-btn").addEventListener("click", async () => {
    if (!pdfBytes || processing) return;
    const password = $("password-input").value;
    if (!password) { setStatus("Enter the PDF password first.", true); return; }
    processing = true; $("process-btn").disabled = true;
    $("spinner").classList.remove("hidden"); $("btn-label").textContent = "Unlocking...";
    setStatus("Decrypting PDF in your browser...");
    try {
      const doc = await PDFDocument.load(pdfBytes, { password });
      const out = await doc.save();
      const blob = new Blob([out], { type: "application/pdf" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url; a.download = `unlocked-${new Date().toISOString().slice(0,10)}.pdf`;
      document.body.appendChild(a); a.click(); a.remove(); URL.revokeObjectURL(url);
      setStatus("Done. Unlocked PDF downloaded — no password needed to open it.");
    } catch (err) {
      console.error(err);
      const msg = err?.message?.toLowerCase() || "";
      if (msg.includes("password") || msg.includes("incorrect") || msg.includes("invalid")) {
        setStatus("Incorrect password. Check the password and try again.", true);
      } else {
        setStatus(`Error: ${err?.message || "could not decrypt this PDF."}`, true);
      }
    } finally {
      processing = false; $("spinner").classList.add("hidden"); $("btn-label").textContent = "Unlock & download"; $("process-btn").disabled = false;
    }
  });
  $("password-input").addEventListener("keydown", e => { if (e.key === "Enter") $("process-btn").click(); });
  window.addEventListener("beforeunload", e => { if (processing) { e.preventDefault(); e.returnValue = ""; } });
</script>
