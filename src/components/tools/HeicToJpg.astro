---
// HEIC to JPG — client-side via heic2any. No upload.
---

<div id="heic-app" class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]">

  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" accept="image/heic,image/heif,.heic,.heif" multiple class="hidden" />
    <div id="empty-state" class="text-center py-4">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
        class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop HEIC files here, or</p>
      <button id="browse-btn" type="button"
        class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">
        choose files
      </button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">HEIC and HEIF files accepted. Multiple files supported. Runs entirely in your browser.</p>
    </div>
  </div>

  <div id="options-wrap" class="hidden px-4 pb-3">
    <label class="text-xs text-[var(--color-ink-muted)] block mb-1">JPG quality</label>
    <select id="quality-select"
      class="w-48 px-3 py-2 border border-[var(--color-rule)] rounded-lg text-sm bg-[var(--color-paper)] text-[var(--color-ink)] focus:outline-none focus:border-[var(--color-accent)]">
      <option value="0.95">High (95%)</option>
      <option value="0.85" selected>Balanced (85%)</option>
      <option value="0.70">Smaller file (70%)</option>
    </select>
  </div>

  <div id="file-list" class="hidden px-4 pb-4 space-y-2"></div>

  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <p id="status-msg" class="text-sm text-[var(--color-ink-muted)]">Drop HEIC photos to convert.</p>
    <div class="flex gap-2">
      <button id="zip-btn" type="button" class="btn-secondary hidden">Download ZIP</button>
      <button id="convert-btn" type="button" class="btn-primary" disabled>
        <span id="btn-label">Convert to JPG</span>
        <svg id="spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12a9 9 0 11-6.219-8.56"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<script type="module">
import heic2any from 'https://esm.sh/heic2any@0.0.4';
import JSZip from 'https://esm.sh/jszip@3.10.1';

let files = [];
let results = []; // { name, blob }

const fileInput  = document.getElementById('file-input');
const dropZone   = document.getElementById('drop-zone');
const fileList   = document.getElementById('file-list');
const convertBtn = document.getElementById('convert-btn');
const statusMsg  = document.getElementById('status-msg');
const zipBtn     = document.getElementById('zip-btn');

document.getElementById('browse-btn').addEventListener('click', () => fileInput.click());
fileInput.addEventListener('change', e => addFiles([...e.target.files]));
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault(); dropZone.classList.remove('drag-over');
  addFiles([...e.dataTransfer.files].filter(f => /\.heic|\.heif|image\/hei/i.test(f.name + f.type)));
});

function addFiles(newFiles) {
  files = [...files, ...newFiles];
  renderList();
  document.getElementById('options-wrap').classList.remove('hidden');
  fileList.classList.remove('hidden');
  convertBtn.disabled = false;
  statusMsg.textContent = `${files.length} file${files.length > 1 ? 's' : ''} ready.`;
}

function renderList() {
  fileList.innerHTML = '';
  files.forEach((f, i) => {
    const row = document.createElement('div');
    row.id = `row-${i}`;
    row.className = 'flex items-center justify-between gap-3 p-2 rounded-lg border border-[var(--color-rule)] text-sm';
    row.innerHTML = `
      <span class="truncate text-[var(--color-ink)] flex-1">${f.name}</span>
      <span class="text-xs text-[var(--color-ink-muted)] shrink-0">${(f.size / 1024).toFixed(0)} KB</span>
      <span id="status-${i}" class="text-xs text-[var(--color-ink-muted)] shrink-0 w-20 text-right">Pending</span>
      <a id="dl-${i}" class="hidden text-xs text-[var(--color-accent)] underline underline-offset-2 shrink-0" download>Download</a>
      <button type="button" data-idx="${i}" class="remove-btn text-xs text-[var(--color-ink-muted)] hover:text-[var(--color-warn)] shrink-0">✕</button>`;
    fileList.appendChild(row);
  });
  document.querySelectorAll('.remove-btn').forEach(btn =>
    btn.addEventListener('click', () => {
      files.splice(parseInt(btn.dataset.idx), 1);
      results = [];
      zipBtn.classList.add('hidden');
      if (!files.length) { fileList.classList.add('hidden'); document.getElementById('options-wrap').classList.add('hidden'); convertBtn.disabled = true; statusMsg.textContent = 'Drop HEIC photos to convert.'; }
      else { renderList(); statusMsg.textContent = `${files.length} file${files.length > 1 ? 's' : ''} ready.`; }
    })
  );
}

convertBtn.addEventListener('click', async () => {
  const btn = convertBtn;
  const label = document.getElementById('btn-label');
  const spinner = document.getElementById('spinner');
  btn.disabled = true; label.textContent = 'Converting…'; spinner.classList.remove('hidden');
  const quality = parseFloat(document.getElementById('quality-select').value);
  results = [];

  for (let i = 0; i < files.length; i++) {
    const statusEl = document.getElementById(`status-${i}`);
    const dlEl = document.getElementById(`dl-${i}`);
    statusEl.textContent = 'Converting…';
    statusEl.className = 'text-xs text-[var(--color-accent)] shrink-0 w-20 text-right';
    try {
      let result = await heic2any({ blob: files[i], toType: 'image/jpeg', quality });
      if (Array.isArray(result)) result = result[0];
      const outName = files[i].name.replace(/\.(heic|heif)$/i, '.jpg');
      results.push({ name: outName, blob: result });
      const url = URL.createObjectURL(result);
      dlEl.href = url; dlEl.download = outName;
      dlEl.textContent = `↓ ${(result.size / 1024).toFixed(0)} KB`;
      dlEl.classList.remove('hidden');
      statusEl.textContent = 'Done';
      statusEl.className = 'text-xs text-[var(--color-ink-muted)] shrink-0 w-20 text-right';
    } catch (err) {
      statusEl.textContent = 'Error';
      statusEl.className = 'text-xs text-[var(--color-warn)] shrink-0 w-20 text-right';
      console.error(err);
    }
  }

  const ok = results.length;
  statusMsg.textContent = `${ok} of ${files.length} converted.`;
  if (ok > 1) zipBtn.classList.remove('hidden');
  btn.disabled = false; label.textContent = 'Convert to JPG'; spinner.classList.add('hidden');
});

zipBtn.addEventListener('click', async () => {
  zipBtn.textContent = 'Zipping…'; zipBtn.disabled = true;
  const zip = new JSZip();
  results.forEach(r => zip.file(r.name, r.blob));
  const blob = await zip.generateAsync({ type: 'blob' });
  const url = URL.createObjectURL(blob);
  Object.assign(document.createElement('a'), { href: url, download: 'heic-to-jpg.zip' }).click();
  setTimeout(() => URL.revokeObjectURL(url), 15000);
  zipBtn.textContent = 'Download ZIP'; zipBtn.disabled = false;
});
</script>
