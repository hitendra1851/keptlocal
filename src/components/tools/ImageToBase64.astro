---
---

<div id="b64-app" class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]">
  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" accept="image/*" class="hidden" />
    <div id="empty-state">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop an image here, or</p>
      <button type="button" id="browse-btn" class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">choose a file from your device</button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">JPG, PNG, WebP, GIF, SVG · Files never leave your browser.</p>
    </div>
  </div>

  <div id="result-wrap" class="hidden px-4 pb-4 space-y-3">
    <div class="flex items-center justify-between gap-3 flex-wrap">
      <div>
        <span id="result-info" class="text-sm text-[var(--color-ink-soft)]"></span>
      </div>
      <div class="flex gap-2 flex-wrap">
        <button type="button" id="format-uri-btn" class="text-xs px-3 py-1.5 rounded-md border border-[var(--color-accent)] bg-[var(--color-accent-tint)] text-[var(--color-accent)] transition-colors">Data URI</button>
        <button type="button" id="format-raw-btn" class="text-xs px-3 py-1.5 rounded-md border border-[var(--color-rule)] text-[var(--color-ink-soft)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors">Base64 only</button>
        <button type="button" id="copy-btn" class="text-xs px-3 py-1.5 rounded-md border border-[var(--color-rule)] text-[var(--color-ink-soft)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors">Copy</button>
        <button type="button" id="clear-btn" class="text-xs px-3 py-1.5 rounded-md text-[var(--color-ink-muted)] hover:text-[var(--color-warn)] transition-colors">Clear</button>
      </div>
    </div>
    <textarea id="output" readonly rows="8"
      class="w-full px-3 py-2.5 text-xs font-mono rounded-md border border-[var(--color-rule)] bg-[var(--color-paper-dark)] text-[var(--color-ink-soft)] resize-y focus:outline-none break-all"
    ></textarea>
    <div class="text-xs text-[var(--color-ink-muted)] space-y-1">
      <p>Use in HTML: <code class="bg-[var(--color-paper-dark)] px-1 rounded">&#60;img src="[paste here]"&#62;</code></p>
      <p>Use in CSS: <code class="bg-[var(--color-paper-dark)] px-1 rounded">background-image: url('[paste here]')</code></p>
    </div>
  </div>

  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <div id="status-msg" class="text-sm text-[var(--color-ink-muted)] min-h-[1.25rem]">Drop an image to get its Base64 string.</div>
  </div>
</div>

<script type="module">
  let dataUri = "";
  let rawBase64 = "";
  let showUri = true;
  const $ = id => document.getElementById(id);
  const setStatus = (msg, err=false) => { $("status-msg").textContent = msg; $("status-msg").style.color = err ? "var(--color-warn)" : ""; };
  const fmtSize = b => b < 1048576 ? `${(b/1024).toFixed(1)} KB` : `${(b/1048576).toFixed(1)} MB`;

  const updateOutput = () => {
    $("output").value = showUri ? dataUri : rawBase64;
  };

  const loadFile = file => {
    if (!file.type.startsWith("image/")) { setStatus("Only image files are accepted.", true); return; }
    const reader = new FileReader();
    reader.onload = e => {
      dataUri = e.target.result;
      rawBase64 = dataUri.split(",")[1] || "";
      const chars = dataUri.length;
      $("result-info").textContent = `${file.name} · ${fmtSize(file.size)} → ${fmtSize(chars)} string`;
      $("empty-state").classList.add("hidden");
      $("result-wrap").classList.remove("hidden");
      updateOutput();
      setStatus("Base64 string ready — copy or use directly.");
    };
    reader.onerror = () => setStatus("Could not read the file.", true);
    reader.readAsDataURL(file);
  };

  $("browse-btn").addEventListener("click", () => $("file-input").click());
  $("drop-zone").addEventListener("click", e => { if (e.target === $("drop-zone") || e.target === $("empty-state")) $("file-input").click(); });
  $("file-input").addEventListener("change", e => { if (e.target.files[0]) loadFile(e.target.files[0]); $("file-input").value = ""; });
  const dz = $("drop-zone");
  ["dragenter","dragover"].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.add("dragging"); }));
  ["dragleave","drop"].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.remove("dragging"); }));
  dz.addEventListener("drop", e => { if (e.dataTransfer?.files[0]) loadFile(e.dataTransfer.files[0]); });

  $("format-uri-btn").addEventListener("click", () => {
    showUri = true; updateOutput();
    $("format-uri-btn").className = "text-xs px-3 py-1.5 rounded-md border border-[var(--color-accent)] bg-[var(--color-accent-tint)] text-[var(--color-accent)] transition-colors";
    $("format-raw-btn").className = "text-xs px-3 py-1.5 rounded-md border border-[var(--color-rule)] text-[var(--color-ink-soft)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors";
  });
  $("format-raw-btn").addEventListener("click", () => {
    showUri = false; updateOutput();
    $("format-raw-btn").className = "text-xs px-3 py-1.5 rounded-md border border-[var(--color-accent)] bg-[var(--color-accent-tint)] text-[var(--color-accent)] transition-colors";
    $("format-uri-btn").className = "text-xs px-3 py-1.5 rounded-md border border-[var(--color-rule)] text-[var(--color-ink-soft)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors";
  });

  $("copy-btn").addEventListener("click", async () => {
    const text = $("output").value;
    if (!text) return;
    try { await navigator.clipboard.writeText(text); } catch { $("output").select(); document.execCommand("copy"); }
    $("copy-btn").textContent = "Copied!";
    setTimeout(() => { $("copy-btn").textContent = "Copy"; }, 2000);
  });

  $("clear-btn").addEventListener("click", () => {
    dataUri = ""; rawBase64 = "";
    $("empty-state").classList.remove("hidden"); $("result-wrap").classList.add("hidden");
    setStatus("Drop an image to get its Base64 string.");
  });
</script>
