---
---

<div id="pdf-png-app" class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]">
  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" accept="application/pdf,.pdf" class="hidden" />
    <div id="empty-state">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop a PDF here, or</p>
      <button type="button" id="browse-btn" class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">choose a file from your device</button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">Files never leave your browser.</p>
    </div>
  </div>

  <div id="controls" class="hidden px-4 pb-4 space-y-4">
    <div class="flex items-center gap-3 p-3 bg-[var(--color-paper-dark)] rounded-lg border border-[var(--color-rule)]">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-accent)] shrink-0">
        <path d="M9 12h6m-6 4h6m-7-8h.01M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <div class="flex-1 min-w-0">
        <div id="file-name" class="text-sm text-[var(--color-ink)] truncate"></div>
        <div id="file-info" class="text-xs text-[var(--color-ink-muted)]"></div>
      </div>
      <button type="button" id="clear-btn" class="text-xs text-[var(--color-ink-muted)] hover:text-[var(--color-warn)] shrink-0">Remove</button>
    </div>
    <div>
      <label class="block text-sm font-medium text-[var(--color-ink)] mb-2">Quality / scale</label>
      <div class="grid grid-cols-3 gap-2">
        {["Standard (1.5×)", "High (2×)", "Best (3×)"].map((label, i) => (
          <label class="flex items-center gap-2 cursor-pointer p-2.5 rounded-md border border-[var(--color-rule)] hover:border-[var(--color-accent)] has-[:checked]:border-[var(--color-accent)] has-[:checked]:bg-[var(--color-accent-tint)] transition-colors">
            <input type="radio" name="scale" value={[1.5,2,3][i]} class="accent-[var(--color-accent)]" checked={i===0} />
            <span class="text-xs text-[var(--color-ink-soft)]">{label}</span>
          </label>
        ))}
      </div>
    </div>
    <div id="preview-list" class="hidden space-y-2"></div>
  </div>

  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <div id="status-msg" class="text-sm text-[var(--color-ink-muted)] min-h-[1.25rem]">Drop a PDF to convert its pages to PNG.</div>
    <div class="flex gap-2 flex-wrap justify-end">
      <button type="button" id="download-zip-btn" class="btn-secondary hidden">Download ZIP</button>
      <button type="button" id="process-btn" class="btn-primary" disabled>
        <span id="btn-label">Convert to PNG</span>
        <svg id="spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56" /></svg>
      </button>
    </div>
  </div>
</div>

<script type="module">
  const PDFJS = "https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.min.js";
  const WORKER = "https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.worker.min.js";

  let pdfFile = null;
  let blobs = [];
  let processing = false;
  const $ = id => document.getElementById(id);
  const fmtSize = b => b < 1048576 ? `${(b/1024).toFixed(1)} KB` : `${(b/1048576).toFixed(1)} MB`;
  const setStatus = (msg, err=false) => { $("status-msg").textContent = msg; $("status-msg").style.color = err ? "var(--color-warn)" : ""; };

  const loadFile = file => {
    if (!file.name.toLowerCase().endsWith(".pdf") && file.type !== "application/pdf") { setStatus("Only PDF files accepted.", true); return; }
    pdfFile = file; blobs = [];
    $("preview-list").innerHTML = ""; $("preview-list").classList.add("hidden");
    $("download-zip-btn").classList.add("hidden");
    $("empty-state").classList.add("hidden"); $("controls").classList.remove("hidden");
    $("process-btn").disabled = false;
    setStatus(`${file.name} (${fmtSize(file.size)}) — click Convert to PNG.`);
  };

  $("browse-btn").addEventListener("click", () => $("file-input").click());
  $("drop-zone").addEventListener("click", e => { if (e.target === $("drop-zone") || e.target === $("empty-state")) $("file-input").click(); });
  $("file-input").addEventListener("change", e => { if (e.target.files[0]) loadFile(e.target.files[0]); $("file-input").value = ""; });
  const dz = $("drop-zone");
  ["dragenter","dragover"].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.add("dragging"); }));
  ["dragleave","drop"].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.remove("dragging"); }));
  dz.addEventListener("drop", e => { if (e.dataTransfer?.files[0]) loadFile(e.dataTransfer.files[0]); });

  $("clear-btn").addEventListener("click", () => {
    pdfFile = null; blobs = [];
    $("empty-state").classList.remove("hidden"); $("controls").classList.add("hidden");
    $("preview-list").innerHTML = ""; $("download-zip-btn").classList.add("hidden");
    $("process-btn").disabled = true;
    setStatus("Drop a PDF to convert its pages to PNG.");
  });

  $("process-btn").addEventListener("click", async () => {
    if (!pdfFile || processing) return;
    const scale = parseFloat(document.querySelector('input[name="scale"]:checked')?.value || "1.5");
    processing = true; $("process-btn").disabled = true;
    $("spinner").classList.remove("hidden"); $("btn-label").textContent = "Converting...";
    blobs = [];
    try {
      if (!window.pdfjsLib) {
        await new Promise((res, rej) => { const s = document.createElement("script"); s.src = PDFJS; s.onload = res; s.onerror = rej; document.head.appendChild(s); });
      }
      pdfjsLib.GlobalWorkerOptions.workerSrc = WORKER;
      const bytes = await pdfFile.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: bytes }).promise;
      const n = pdf.numPages;
      const list = $("preview-list");
      list.innerHTML = ""; list.classList.remove("hidden");

      for (let i = 1; i <= n; i++) {
        setStatus(`Rendering page ${i} of ${n}...`);
        const page = await pdf.getPage(i);
        const vp = page.getViewport({ scale });
        const canvas = document.createElement("canvas");
        canvas.width = vp.width; canvas.height = vp.height;
        await page.render({ canvasContext: canvas.getContext("2d"), viewport: vp }).promise;
        const blob = await new Promise(res => canvas.toBlob(res, "image/png"));
        blobs.push({ blob, name: `page-${String(i).padStart(3,"0")}.png` });

        const url = URL.createObjectURL(blob);
        const row = document.createElement("div");
        row.className = "flex items-center justify-between gap-3 px-3 py-2 bg-[var(--color-paper-dark)] rounded-md border border-[var(--color-rule)]";
        row.innerHTML = `<span class="text-sm text-[var(--color-ink)] truncate">Page ${i} <span class="text-xs text-[var(--color-ink-muted)]">(${fmtSize(blob.size)})</span></span><a href="${url}" download="page-${String(i).padStart(3,"0")}.png" class="text-xs text-[var(--color-accent)] hover:underline underline-offset-4 shrink-0">Save</a>`;
        list.appendChild(row);
      }

      if (n > 1) {
        const JSZip = (await import("https://esm.sh/jszip@3.10.1")).default;
        const zip = new JSZip();
        blobs.forEach(({ blob, name }) => zip.file(name, blob));
        const zipBlob = await zip.generateAsync({ type: "blob" });
        const zipUrl = URL.createObjectURL(zipBlob);
        const btn = $("download-zip-btn");
        btn.classList.remove("hidden");
        btn.onclick = () => { const a = document.createElement("a"); a.href = zipUrl; a.download = `pdf-pages-png-${new Date().toISOString().slice(0,10)}.zip`; document.body.appendChild(a); a.click(); a.remove(); };
      } else if (blobs.length === 1) {
        const a = document.createElement("a"); a.href = URL.createObjectURL(blobs[0].blob); a.download = "page-001.png"; document.body.appendChild(a); a.click(); a.remove();
      }
      setStatus(`Done. ${n} PNG${n>1?"s":""} ready.`);
    } catch (err) {
      console.error(err); setStatus(`Error: ${err?.message || "could not convert this PDF."}`, true);
    } finally {
      processing = false; $("spinner").classList.add("hidden"); $("btn-label").textContent = "Convert to PNG"; $("process-btn").disabled = false;
    }
  });
</script>
