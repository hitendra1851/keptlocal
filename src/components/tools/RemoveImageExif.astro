---
---

<div id="exif-app" class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]">
  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" accept="image/jpeg,image/jpg,image/png" multiple class="hidden" />
    <div id="empty-state">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop photos here, or</p>
      <button type="button" id="browse-btn" class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">choose files from your device</button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">JPG &amp; PNG · Strips GPS, camera data, date taken · Files never leave your browser.</p>
    </div>
  </div>

  <div id="results" class="hidden px-4 pb-4 space-y-2"></div>

  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <div id="status-msg" class="text-sm text-[var(--color-ink-muted)] min-h-[1.25rem]">Drop photos to strip metadata.</div>
    <div class="flex gap-2 flex-wrap justify-end">
      <button type="button" id="zip-btn" class="btn-secondary hidden">Download ZIP</button>
      <button type="button" id="process-btn" class="btn-primary" disabled>
        <span id="btn-label">Strip metadata</span>
        <svg id="spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56" /></svg>
      </button>
    </div>
  </div>
</div>

<script type="module">
  let files = [];
  let resultBlobs = [];
  const $ = id => document.getElementById(id);
  const setStatus = (msg, err = false) => { $('status-msg').textContent = msg; $('status-msg').style.color = err ? 'var(--color-warn)' : ''; };
  const fmtSize = b => b < 1048576 ? `${(b/1024).toFixed(1)} KB` : `${(b/1048576).toFixed(1)} MB`;

  const readExifTags = async (file) => {
    if (file.type !== 'image/jpeg' && file.type !== 'image/jpg') return null;
    try {
      const exifr = await import('https://esm.sh/exifr@7.1.3');
      const parsed = await exifr.default.parse(file, { gps: true, tiff: true, exif: true, xmp: false, iptc: false });
      if (!parsed) return null;
      const tags = [];
      if (parsed.latitude != null) tags.push('GPS coordinates');
      if (parsed.Make || parsed.Model) tags.push(`camera: ${[parsed.Make, parsed.Model].filter(Boolean).join(' ')}`);
      if (parsed.DateTimeOriginal) tags.push(`date taken: ${new Date(parsed.DateTimeOriginal).toLocaleDateString()}`);
      if (parsed.Software) tags.push(`software: ${parsed.Software}`);
      if (parsed.Copyright) tags.push('copyright info');
      return tags.length ? tags : ['metadata found'];
    } catch { return null; }
  };

  const stripAndDownload = async (file) => {
    const tags = await readExifTags(file);
    const bitmap = await createImageBitmap(file);
    const canvas = document.createElement('canvas');
    canvas.width = bitmap.width; canvas.height = bitmap.height;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(bitmap, 0, 0);
    const fmt = file.type === 'image/png' ? 'image/png' : 'image/jpeg';
    const ext = fmt === 'image/png' ? 'png' : 'jpg';
    const blob = await new Promise(res => canvas.toBlob(res, fmt, 0.95));
    const base = file.name.replace(/\.[^.]+$/, '');
    return { blob, name: `${base}-clean.${ext}`, tags };
  };

  const addFiles = newFiles => {
    const imgs = Array.from(newFiles).filter(f => f.type === 'image/jpeg' || f.type === 'image/jpg' || f.type === 'image/png');
    if (!imgs.length) { setStatus('Only JPG and PNG files are accepted.', true); return; }
    files = [...files, ...imgs];
    $('empty-state').classList.add('hidden'); $('process-btn').disabled = false;
    setStatus(`${files.length} image${files.length > 1 ? 's' : ''} ready — click Strip metadata.`);
  };

  $('browse-btn').addEventListener('click', () => $('file-input').click());
  $('file-input').addEventListener('change', e => { if (e.target.files.length) addFiles(e.target.files); $('file-input').value = ''; });
  const dz = $('drop-zone');
  ['dragenter','dragover'].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.add('dragging'); }));
  ['dragleave','drop'].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.remove('dragging'); }));
  dz.addEventListener('drop', e => { if (e.dataTransfer?.files.length) addFiles(e.dataTransfer.files); });

  $('process-btn').addEventListener('click', async () => {
    if (!files.length) return;
    $('process-btn').disabled = true; $('spinner').classList.remove('hidden'); $('btn-label').textContent = 'Processing…';
    resultBlobs = [];
    const list = $('results');
    list.innerHTML = ''; list.classList.remove('hidden');

    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      setStatus(`Processing ${i + 1} of ${files.length}: ${file.name}`);
      try {
        const { blob, name, tags } = await stripAndDownload(file);
        resultBlobs.push({ blob, name });
        const url = URL.createObjectURL(blob);
        const tagText = tags ? `Stripped: ${tags.join(', ')}` : 'No EXIF found (already clean)';
        const row = document.createElement('div');
        row.className = 'rounded-lg border border-[var(--color-rule)] bg-[var(--color-paper-dark)] overflow-hidden';
        row.innerHTML = `
          <div class="flex items-center justify-between gap-3 px-3 py-2">
            <div class="min-w-0">
              <span class="text-sm text-[var(--color-ink)] truncate block">${file.name}</span>
              <span class="text-xs text-[var(--color-ink-muted)]">${fmtSize(file.size)} → ${fmtSize(blob.size)}</span>
            </div>
            <a href="${url}" download="${name}" class="text-xs text-[var(--color-accent)] hover:underline underline-offset-4 shrink-0">Save</a>
          </div>
          <div class="px-3 py-1.5 border-t border-[var(--color-rule)] bg-[var(--color-accent-tint)]">
            <p class="text-xs text-[var(--color-accent)]">${tagText}</p>
          </div>`;
        list.appendChild(row);
      } catch (err) {
        const row = document.createElement('div');
        row.className = 'px-3 py-2 bg-[var(--color-paper-dark)] rounded-lg border border-[var(--color-rule)]';
        row.innerHTML = `<span class="text-sm text-[var(--color-warn)]">${file.name} — failed to process</span>`;
        list.appendChild(row);
      }
    }

    if (resultBlobs.length > 1) {
      const { default: JSZip } = await import('https://esm.sh/jszip@3.10.1');
      const zip = new JSZip();
      resultBlobs.forEach(({ blob, name }) => zip.file(name, blob));
      const zipBlob = await zip.generateAsync({ type: 'blob' });
      const zipUrl = URL.createObjectURL(zipBlob);
      const btn = $('zip-btn');
      btn.classList.remove('hidden');
      btn.onclick = () => { const a = document.createElement('a'); a.href = zipUrl; a.download = `clean-images-${new Date().toISOString().slice(0,10)}.zip`; document.body.appendChild(a); a.click(); a.remove(); };
    } else if (resultBlobs.length === 1) {
      const a = document.createElement('a'); a.href = URL.createObjectURL(resultBlobs[0].blob); a.download = resultBlobs[0].name;
      document.body.appendChild(a); a.click(); a.remove();
    }

    setStatus(`Done. ${resultBlobs.length} image${resultBlobs.length > 1 ? 's' : ''} cleaned.`);
    $('spinner').classList.add('hidden'); $('btn-label').textContent = 'Strip metadata'; $('process-btn').disabled = false;
  });
</script>
