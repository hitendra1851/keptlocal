---
// Resize Image — Canvas API, all processing client-side
---

<div
  id="resize-image-app"
  class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]"
>
  <!-- Drop zone -->
  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" accept="image/jpeg,image/jpg,image/png,image/webp,.jpg,.jpeg,.png,.webp" class="hidden" />
    <div id="empty-state">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M4 4h6v6H4V4zm10 10h6v6h-6v-6zM4 14h6v6H4v-6zm10-10h6v6h-6V4z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop an image here, or</p>
      <button type="button" id="browse-btn" class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">
        choose a file from your device
      </button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">JPG, PNG, WebP · Files never leave your browser.</p>
    </div>
  </div>

  <!-- Controls -->
  <div id="controls" class="hidden px-4 pb-4 space-y-5">
    <!-- File info -->
    <div class="flex items-center gap-3 px-3 py-2.5 bg-[var(--color-paper-dark)] rounded-md">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-accent)] shrink-0">
        <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <div class="flex-1 min-w-0">
        <div id="file-name" class="text-sm text-[var(--color-ink)] truncate"></div>
        <div id="file-meta" class="text-xs text-[var(--color-ink-muted)]"></div>
      </div>
      <button type="button" id="change-file-btn" class="text-xs text-[var(--color-ink-muted)] hover:text-[var(--color-accent)] shrink-0">Change</button>
    </div>

    <!-- Resize mode tabs -->
    <div>
      <p class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] font-medium mb-2">Resize by</p>
      <div class="flex gap-2">
        <button type="button" data-mode="dimensions" class="mode-btn flex-1 py-2 rounded-lg border text-sm font-medium transition-colors">Dimensions</button>
        <button type="button" data-mode="percentage" class="mode-btn flex-1 py-2 rounded-lg border text-sm font-medium transition-colors">Percentage</button>
        <button type="button" data-mode="longest" class="mode-btn flex-1 py-2 rounded-lg border text-sm font-medium transition-colors">Longest side</button>
      </div>
    </div>

    <!-- Dimension inputs -->
    <div id="mode-dimensions">
      <div class="flex items-center gap-3">
        <div class="flex-1">
          <label for="input-width" class="block text-xs text-[var(--color-ink-muted)] mb-1">Width (px)</label>
          <input type="number" id="input-width" min="1" max="16000" class="w-full px-3 py-2 rounded-md border border-[var(--color-rule)] bg-[var(--color-paper)] text-[var(--color-ink)] text-sm focus:outline-none focus:border-[var(--color-accent)]" />
        </div>
        <div class="flex items-end pb-2">
          <button type="button" id="lock-btn" title="Lock aspect ratio" class="text-[var(--color-accent)] hover:opacity-70 transition-opacity">
            <svg id="lock-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
        <div class="flex-1">
          <label for="input-height" class="block text-xs text-[var(--color-ink-muted)] mb-1">Height (px)</label>
          <input type="number" id="input-height" min="1" max="16000" class="w-full px-3 py-2 rounded-md border border-[var(--color-rule)] bg-[var(--color-paper)] text-[var(--color-ink)] text-sm focus:outline-none focus:border-[var(--color-accent)]" />
        </div>
      </div>
      <p class="text-xs text-[var(--color-ink-muted)] mt-2">Lock icon keeps aspect ratio. Unlock to set both dimensions freely.</p>
    </div>

    <!-- Percentage input -->
    <div id="mode-percentage" class="hidden">
      <label for="input-pct" class="block text-xs text-[var(--color-ink-muted)] mb-1">Scale (%)</label>
      <input type="number" id="input-pct" min="1" max="400" value="50" class="w-full px-3 py-2 rounded-md border border-[var(--color-rule)] bg-[var(--color-paper)] text-[var(--color-ink)] text-sm focus:outline-none focus:border-[var(--color-accent)]" />
      <p id="pct-preview" class="text-xs text-[var(--color-ink-muted)] mt-2"></p>
    </div>

    <!-- Longest side input -->
    <div id="mode-longest" class="hidden">
      <label for="input-longest" class="block text-xs text-[var(--color-ink-muted)] mb-1">Longest side (px)</label>
      <input type="number" id="input-longest" min="1" max="16000" value="1920" class="w-full px-3 py-2 rounded-md border border-[var(--color-rule)] bg-[var(--color-paper)] text-[var(--color-ink)] text-sm focus:outline-none focus:border-[var(--color-accent)]" />
      <p id="longest-preview" class="text-xs text-[var(--color-ink-muted)] mt-2"></p>
    </div>

    <!-- Output format -->
    <div>
      <p class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] font-medium mb-2">Output format</p>
      <div class="flex gap-2">
        <button type="button" data-fmt="original" class="fmt-btn flex-1 py-2 rounded-lg border text-sm font-medium transition-colors">Same as input</button>
        <button type="button" data-fmt="image/jpeg" class="fmt-btn flex-1 py-2 rounded-lg border text-sm font-medium transition-colors">JPG</button>
        <button type="button" data-fmt="image/png" class="fmt-btn flex-1 py-2 rounded-lg border text-sm font-medium transition-colors">PNG</button>
        <button type="button" data-fmt="image/webp" class="fmt-btn flex-1 py-2 rounded-lg border text-sm font-medium transition-colors">WebP</button>
      </div>
    </div>
  </div>

  <!-- Action bar -->
  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <div id="status-msg" class="text-sm text-[var(--color-ink-muted)] min-h-[1.25rem]">Upload an image to get started.</div>
    <button type="button" id="resize-btn" class="btn-primary" disabled>
      <span id="resize-label">Resize & download</span>
      <svg id="spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12a9 9 0 11-6.219-8.56" />
      </svg>
    </button>
  </div>
</div>

<script type="module">
  const $ = (id) => document.getElementById(id);
  const dropZone      = $('drop-zone');
  const fileInput     = $('file-input');
  const browseBtn     = $('browse-btn');
  const emptyState    = $('empty-state');
  const controls      = $('controls');
  const fileNameEl    = $('file-name');
  const fileMeta      = $('file-meta');
  const changeFileBtn = $('change-file-btn');
  const resizeBtn     = $('resize-btn');
  const resizeLabel   = $('resize-label');
  const spinner       = $('spinner');
  const statusMsg     = $('status-msg');
  const inputWidth    = $('input-width');
  const inputHeight   = $('input-height');
  const inputPct      = $('input-pct');
  const inputLongest  = $('input-longest');
  const pctPreview    = $('pct-preview');
  const longestPreview= $('longest-preview');
  const lockBtn       = $('lock-btn');
  const lockIcon      = $('lock-icon');

  let imgEl = null;
  let origW = 0, origH = 0;
  let fileName = '';
  let fileType = '';
  let locked = true;
  let mode = 'dimensions';
  let outFmt = 'original';
  let processing = false;

  const fmtSize = (b) =>
    b < 1024 ? `${b} B`
    : b < 1024 * 1024 ? `${(b / 1024).toFixed(1)} KB`
    : `${(b / 1024 / 1024).toFixed(2)} MB`;

  const setStatus = (msg, isError = false) => {
    statusMsg.textContent = msg;
    statusMsg.style.color = isError ? 'var(--color-warn)' : '';
  };

  // Mode buttons
  const modeBtns = document.querySelectorAll('.mode-btn');
  const setMode = (m) => {
    mode = m;
    modeBtns.forEach((btn) => {
      const active = btn.dataset.mode === m;
      btn.classList.toggle('border-[var(--color-accent)]', active);
      btn.classList.toggle('bg-[var(--color-accent-tint)]', active);
      btn.classList.toggle('text-[var(--color-accent)]', active);
      btn.classList.toggle('border-[var(--color-rule)]', !active);
      btn.classList.toggle('text-[var(--color-ink-soft)]', !active);
    });
    $('mode-dimensions').classList.toggle('hidden', m !== 'dimensions');
    $('mode-percentage').classList.toggle('hidden', m !== 'percentage');
    $('mode-longest').classList.toggle('hidden', m !== 'longest');
    updatePreviews();
  };
  modeBtns.forEach((btn) => btn.addEventListener('click', () => setMode(btn.dataset.mode)));

  // Format buttons
  const fmtBtns = document.querySelectorAll('.fmt-btn');
  const setFmt = (f) => {
    outFmt = f;
    fmtBtns.forEach((btn) => {
      const active = btn.dataset.fmt === f;
      btn.classList.toggle('border-[var(--color-accent)]', active);
      btn.classList.toggle('bg-[var(--color-accent-tint)]', active);
      btn.classList.toggle('text-[var(--color-accent)]', active);
      btn.classList.toggle('border-[var(--color-rule)]', !active);
      btn.classList.toggle('text-[var(--color-ink-soft)]', !active);
    });
  };
  fmtBtns.forEach((btn) => btn.addEventListener('click', () => setFmt(btn.dataset.fmt)));
  setFmt('original');

  // Lock aspect ratio
  const LOCKED_PATH   = 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z';
  const UNLOCKED_PATH = 'M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z';
  lockBtn.addEventListener('click', () => {
    locked = !locked;
    lockIcon.querySelector('path').setAttribute('d', locked ? LOCKED_PATH : UNLOCKED_PATH);
    if (locked && origW > 0) syncFromWidth();
  });

  const syncFromWidth = () => {
    const w = parseInt(inputWidth.value, 10);
    if (!isNaN(w) && w > 0 && origW > 0) {
      inputHeight.value = Math.round(w * origH / origW);
    }
  };
  const syncFromHeight = () => {
    const h = parseInt(inputHeight.value, 10);
    if (!isNaN(h) && h > 0 && origW > 0) {
      inputWidth.value = Math.round(h * origW / origH);
    }
  };
  inputWidth.addEventListener('input', () => { if (locked) syncFromWidth(); });
  inputHeight.addEventListener('input', () => { if (locked) syncFromHeight(); });

  const updatePreviews = () => {
    if (!origW) return;
    const pct = parseFloat(inputPct.value) || 50;
    pctPreview.textContent = `Output: ${Math.round(origW * pct / 100)} × ${Math.round(origH * pct / 100)} px`;

    const longest = parseInt(inputLongest.value, 10) || 1920;
    const scale = Math.min(longest / origW, longest / origH, 1);
    longestPreview.textContent = `Output: ${Math.round(origW * scale)} × ${Math.round(origH * scale)} px`;
  };
  inputPct.addEventListener('input', updatePreviews);
  inputLongest.addEventListener('input', updatePreviews);

  const loadFile = (file) => {
    const accepted = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'].includes(file.type)
      || /\.(jpg|jpeg|png|webp)$/i.test(file.name);
    if (!accepted) { setStatus('Only JPG, PNG, and WebP images are accepted.', true); return; }

    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => {
        imgEl = img;
        origW = img.naturalWidth;
        origH = img.naturalHeight;
        fileName = file.name.replace(/\.[^.]+$/, '');
        fileType = file.type || 'image/jpeg';

        fileNameEl.textContent = file.name;
        fileMeta.textContent = `${origW} × ${origH} px · ${fmtSize(file.size)}`;
        inputWidth.value = origW;
        inputHeight.value = origH;
        updatePreviews();

        emptyState.classList.add('hidden');
        controls.classList.remove('hidden');
        resizeBtn.disabled = false;
        setStatus(`Ready — original size ${origW} × ${origH} px.`);
        setMode('dimensions');
        setFmt('original');
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  };

  const reset = () => {
    imgEl = null; origW = 0; origH = 0;
    emptyState.classList.remove('hidden');
    controls.classList.add('hidden');
    resizeBtn.disabled = true;
    setStatus('Upload an image to get started.');
  };

  const getTargetDimensions = () => {
    if (mode === 'dimensions') {
      return { w: Math.max(1, parseInt(inputWidth.value, 10) || origW), h: Math.max(1, parseInt(inputHeight.value, 10) || origH) };
    }
    if (mode === 'percentage') {
      const pct = Math.max(1, parseFloat(inputPct.value) || 50) / 100;
      return { w: Math.round(origW * pct), h: Math.round(origH * pct) };
    }
    // longest side
    const longest = Math.max(1, parseInt(inputLongest.value, 10) || 1920);
    const scale = Math.min(longest / origW, longest / origH, 1);
    return { w: Math.round(origW * scale), h: Math.round(origH * scale) };
  };

  resizeBtn.addEventListener('click', async () => {
    if (!imgEl || processing) return;
    processing = true;
    resizeBtn.disabled = true;
    spinner.classList.remove('hidden');
    resizeLabel.textContent = 'Resizing…';
    setStatus('Resizing in your browser…');

    await new Promise((r) => setTimeout(r, 0)); // yield to paint

    try {
      const { w, h } = getTargetDimensions();
      const canvas = document.createElement('canvas');
      canvas.width = w; canvas.height = h;
      const ctx = canvas.getContext('2d');
      ctx.drawImage(imgEl, 0, 0, w, h);

      const mimeType = outFmt === 'original' ? fileType : outFmt;
      const quality  = mimeType === 'image/png' ? 1 : 0.92;
      const ext      = mimeType === 'image/jpeg' ? 'jpg' : mimeType === 'image/webp' ? 'webp' : 'png';

      const blob = await new Promise((res) => canvas.toBlob(res, mimeType, quality));
      const url  = URL.createObjectURL(blob);
      const a    = document.createElement('a');
      a.href = url; a.download = `${fileName}-${w}x${h}.${ext}`;
      document.body.appendChild(a); a.click(); a.remove();
      URL.revokeObjectURL(url);

      setStatus(`Downloaded — ${w} × ${h} px, ${fmtSize(blob.size)}.`);
    } catch (err) {
      console.error(err);
      setStatus(`Error: ${err?.message || 'resize failed.'}`, true);
    } finally {
      processing = false;
      spinner.classList.add('hidden');
      resizeLabel.textContent = 'Resize & download';
      resizeBtn.disabled = false;
    }
  });

  browseBtn?.addEventListener('click', () => fileInput.click());
  changeFileBtn?.addEventListener('click', () => { reset(); fileInput.click(); });
  fileInput.addEventListener('change', (e) => {
    if (e.target.files?.[0]) loadFile(e.target.files[0]);
    fileInput.value = '';
  });
  ['dragenter', 'dragover'].forEach((ev) =>
    dropZone.addEventListener(ev, (e) => { e.preventDefault(); dropZone.classList.add('dragging'); })
  );
  ['dragleave', 'drop'].forEach((ev) =>
    dropZone.addEventListener(ev, (e) => { e.preventDefault(); dropZone.classList.remove('dragging'); })
  );
  dropZone.addEventListener('drop', (e) => {
    if (e.dataTransfer?.files?.[0]) loadFile(e.dataTransfer.files[0]);
  });
  dropZone.addEventListener('click', (e) => {
    if (e.target === dropZone || e.target === emptyState) fileInput.click();
  });
</script>
