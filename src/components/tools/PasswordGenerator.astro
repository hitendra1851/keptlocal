---
---

<div id="pw-app" class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]">
  <div class="p-5 space-y-5">

    <!-- Output -->
    <div class="relative">
      <div id="pw-output" class="font-mono text-lg text-[var(--color-ink)] bg-[var(--color-paper-dark)] border border-[var(--color-rule)] rounded-lg px-4 py-4 pr-20 tracking-wide break-all min-h-[3.5rem] flex items-center select-all">
        <span id="pw-text" class="text-[var(--color-ink-muted)] text-base font-sans">Click Generate to create a password</span>
      </div>
      <button id="copy-btn" type="button" title="Copy" class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-medium border border-[var(--color-rule)] bg-[var(--color-paper)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors text-[var(--color-ink-muted)]">
        <svg id="copy-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-linecap="round"/></svg>
        <span id="copy-label">Copy</span>
      </button>
    </div>

    <!-- Strength bar -->
    <div id="strength-section" class="hidden">
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs text-[var(--color-ink-muted)]">Strength</span>
        <span id="strength-label" class="text-xs font-medium"></span>
      </div>
      <div class="h-1.5 bg-[var(--color-paper-dark)] rounded-full overflow-hidden">
        <div id="strength-bar" class="h-full rounded-full transition-all duration-300" style="width:0%"></div>
      </div>
    </div>

    <!-- Length -->
    <div>
      <div class="flex items-center justify-between mb-2">
        <label class="text-sm font-medium text-[var(--color-ink)]">Length</label>
        <span id="length-display" class="text-sm font-mono font-semibold text-[var(--color-accent)]">16</span>
      </div>
      <input type="range" id="length-slider" min="8" max="64" value="16" step="1"
        class="w-full accent-[var(--color-accent)] cursor-pointer" />
      <div class="flex justify-between text-xs text-[var(--color-ink-muted)] mt-1">
        <span>8</span><span>64</span>
      </div>
    </div>

    <!-- Character sets -->
    <div class="grid grid-cols-2 gap-2">
      {[
        { id: 'opt-upper', label: 'Uppercase (A–Z)', defaultChecked: true },
        { id: 'opt-lower', label: 'Lowercase (a–z)', defaultChecked: true },
        { id: 'opt-nums',  label: 'Numbers (0–9)',    defaultChecked: true },
        { id: 'opt-syms',  label: 'Symbols (!@#…)',   defaultChecked: true },
      ].map(({ id, label, defaultChecked }) => (
        <label class="flex items-center gap-2 cursor-pointer text-sm text-[var(--color-ink-soft)]">
          <input type="checkbox" id={id} checked={defaultChecked}
            class="accent-[var(--color-accent)] w-3.5 h-3.5 cursor-pointer" />
          {label}
        </label>
      ))}
    </div>

    <!-- Exclude ambiguous -->
    <label class="flex items-center gap-2 cursor-pointer text-sm text-[var(--color-ink-soft)]">
      <input type="checkbox" id="opt-noambig" class="accent-[var(--color-accent)] w-3.5 h-3.5 cursor-pointer" />
      Exclude ambiguous characters (0, O, l, 1, I)
    </label>
  </div>

  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <div id="status-msg" class="text-sm text-[var(--color-ink-muted)]">Configure options and click Generate.</div>
    <button type="button" id="gen-btn" class="btn-primary">Generate password</button>
  </div>
</div>

<script type="module">
  const $ = id => document.getElementById(id);

  const CHARS = {
    upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
    lower: 'abcdefghijklmnopqrstuvwxyz',
    nums:  '0123456789',
    syms:  '!@#$%^&*()_+-=[]{}|;:,.<>?',
    ambig: /[0Ol1I]/g,
  };

  const buildCharset = () => {
    let cs = '';
    if ($('opt-upper').checked) cs += CHARS.upper;
    if ($('opt-lower').checked) cs += CHARS.lower;
    if ($('opt-nums').checked)  cs += CHARS.nums;
    if ($('opt-syms').checked)  cs += CHARS.syms;
    if ($('opt-noambig').checked) cs = cs.replace(CHARS.ambig, '');
    return cs;
  };

  const getEntropy = (len, charsetSize) => len * Math.log2(charsetSize);

  const strengthInfo = (bits) => {
    if (bits < 40) return { label: 'Very weak', color: '#c0392b', pct: 15 };
    if (bits < 60) return { label: 'Weak',      color: '#e67e22', pct: 35 };
    if (bits < 80) return { label: 'Fair',      color: '#f1c40f', pct: 55 };
    if (bits < 100) return { label: 'Strong',   color: 'var(--color-accent)', pct: 75 };
    return             { label: 'Very strong',  color: 'var(--color-accent)', pct: 100 };
  };

  const generate = () => {
    const cs = buildCharset();
    if (!cs) { $('status-msg').textContent = 'Select at least one character type.'; $('status-msg').style.color = 'var(--color-warn)'; return; }
    const len = parseInt($('length-slider').value);
    const arr = new Uint32Array(len);
    crypto.getRandomValues(arr);
    const pw = Array.from(arr).map(n => cs[n % cs.length]).join('');
    $('pw-text').textContent = pw;
    $('pw-text').style.color = 'var(--color-ink)';
    $('pw-text').style.fontFamily = 'monospace';

    const bits = getEntropy(len, cs.length);
    const info = strengthInfo(bits);
    $('strength-bar').style.width = info.pct + '%';
    $('strength-bar').style.background = info.color;
    $('strength-label').textContent = info.label;
    $('strength-label').style.color = info.color;
    $('strength-section').classList.remove('hidden');
    $('status-msg').textContent = `${len}-character password · ${Math.round(bits)} bits of entropy`;
    $('status-msg').style.color = '';
  };

  $('length-slider').addEventListener('input', () => {
    $('length-display').textContent = $('length-slider').value;
  });

  $('gen-btn').addEventListener('click', generate);

  $('copy-btn').addEventListener('click', () => {
    const pw = $('pw-text').textContent;
    if (!pw || pw === 'Click Generate to create a password') return;
    navigator.clipboard.writeText(pw).then(() => {
      $('copy-label').textContent = 'Copied!';
      setTimeout(() => { $('copy-label').textContent = 'Copy'; }, 1800);
    });
  });

  // Generate on load
  generate();
</script>
