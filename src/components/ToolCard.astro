---
import type { Tool } from "../data/tools";
export interface Props { tool: Tool }
const { tool } = Astro.props;
const isLive = tool.status === "live";
const Tag = isLive ? "a" : "div";
const href = isLive ? `/tools/${tool.slug}` : undefined;
---

<Tag
  href={href}
  class:list={[
    "block group relative p-5 rounded-xl border bg-[var(--color-paper)] transition-all duration-200",
    isLive
      ? "border-[var(--color-rule)] hover:border-[var(--color-accent)] hover:-translate-y-1 hover:shadow-lg hover:shadow-[rgba(45,80,22,0.1)] cursor-pointer"
      : "border-[var(--color-rule)] opacity-55 cursor-default",
  ]}
>
  <div class="flex items-start justify-between mb-4">
    <div class:list={[
      "w-11 h-11 rounded-lg flex items-center justify-center transition-all duration-200",
      isLive
        ? "bg-[var(--color-accent-tint)] text-[var(--color-accent)] group-hover:bg-[var(--color-accent)] group-hover:text-[#faf8f3]"
        : "bg-[var(--color-paper-dark)] text-[var(--color-ink-muted)]",
    ]}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <path d={tool.icon} stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
    {isLive ? (
      <svg
        width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        class="text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-all duration-200 translate-x-[-4px] group-hover:translate-x-0 mt-0.5"
      >
        <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    ) : (
      <span class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] font-medium bg-[var(--color-paper-dark)] px-2 py-0.5 rounded-full">Soon</span>
    )}
  </div>
  <h3 class="font-medium text-[var(--color-ink)] mb-1.5 group-hover:text-[var(--color-accent)] transition-colors duration-200">{tool.name}</h3>
  <p class="text-sm text-[var(--color-ink-muted)] leading-relaxed">{tool.description}</p>
</Tag>
