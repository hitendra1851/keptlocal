---
---

<div id="protect-app" class="border border-[var(--color-rule)] rounded-xl overflow-hidden bg-[var(--color-paper)]">
  <!-- Drop zone -->
  <div id="drop-zone" class="drop-zone m-4">
    <input type="file" id="file-input" accept="application/pdf" class="hidden" />
    <div id="empty-state">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-[var(--color-ink-muted)] mb-3">
        <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-[var(--color-ink-soft)] mb-1">Drop a PDF here, or</p>
      <button type="button" id="browse-btn" class="text-[var(--color-accent)] underline underline-offset-4 font-medium hover:no-underline">choose a file from your device</button>
      <p class="text-xs text-[var(--color-ink-muted)] mt-4">PDF files only · Files never leave your browser.</p>
    </div>
    <div id="file-info" class="hidden text-center">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-[var(--color-accent)] mb-2">
        <path d="M9 12h6m-6 4h6m-7-8h.01M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p id="file-name" class="text-sm font-medium text-[var(--color-ink)]"></p>
      <p id="file-size" class="text-xs text-[var(--color-ink-muted)] mt-0.5"></p>
      <button type="button" id="change-btn" class="mt-2 text-xs text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] underline underline-offset-2">Change file</button>
    </div>
  </div>

  <!-- Password options -->
  <div id="pw-section" class="hidden px-4 pb-4 space-y-3">
    <div class="border-t border-[var(--color-rule)] pt-4">
      <p class="text-sm font-medium text-[var(--color-ink)] mb-3">Set password</p>
      <div class="space-y-2">
        <div class="relative">
          <input type="password" id="pw-input" placeholder="Password" autocomplete="new-password"
            class="w-full px-3 py-2 pr-10 rounded-lg border border-[var(--color-rule)] bg-[var(--color-paper-dark)] text-sm text-[var(--color-ink)] placeholder:text-[var(--color-ink-muted)] focus:outline-none focus:border-[var(--color-accent)]" />
          <button type="button" id="toggle-vis" class="absolute right-2.5 top-1/2 -translate-y-1/2 text-[var(--color-ink-muted)] hover:text-[var(--color-ink)]" title="Show/hide password">
            <svg id="eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          </button>
        </div>
        <input type="password" id="pw-confirm" placeholder="Confirm password" autocomplete="new-password"
          class="w-full px-3 py-2 rounded-lg border border-[var(--color-rule)] bg-[var(--color-paper-dark)] text-sm text-[var(--color-ink)] placeholder:text-[var(--color-ink-muted)] focus:outline-none focus:border-[var(--color-accent)]" />
      </div>
      <p id="pw-match-msg" class="text-xs mt-1.5 hidden"></p>
    </div>
  </div>

  <div class="border-t border-[var(--color-rule)] px-4 py-3 bg-[var(--color-paper-dark)] flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <div id="status-msg" class="text-sm text-[var(--color-ink-muted)]">Drop a PDF to get started.</div>
    <button type="button" id="process-btn" class="btn-primary" disabled>
      <span id="btn-label">Protect PDF</span>
      <svg id="spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56" /></svg>
    </button>
  </div>
</div>

<script type="module">
  const $ = id => document.getElementById(id);
  const fmtSize = b => b < 1048576 ? `${(b/1024).toFixed(1)} KB` : `${(b/1048576).toFixed(1)} MB`;
  const setStatus = (msg, err = false) => { $('status-msg').textContent = msg; $('status-msg').style.color = err ? 'var(--color-warn)' : ''; };

  let pdfFile = null;

  const setFile = f => {
    pdfFile = f;
    $('file-name').textContent = f.name;
    $('file-size').textContent = fmtSize(f.size);
    $('empty-state').classList.add('hidden');
    $('file-info').classList.remove('hidden');
    $('pw-section').classList.remove('hidden');
    setStatus('Set a password and click Protect PDF.');
    validateBtn();
  };

  const validateBtn = () => {
    const pw = $('pw-input').value;
    const conf = $('pw-confirm').value;
    const msg = $('pw-match-msg');
    if (conf && pw !== conf) {
      msg.textContent = 'Passwords do not match.';
      msg.style.color = 'var(--color-warn)';
      msg.classList.remove('hidden');
      $('process-btn').disabled = true;
    } else {
      msg.classList.add('hidden');
      $('process-btn').disabled = !(pdfFile && pw.length > 0);
    }
  };

  $('browse-btn').addEventListener('click', () => $('file-input').click());
  $('change-btn').addEventListener('click', () => { $('file-input').click(); });
  $('file-input').addEventListener('change', e => { if (e.target.files[0]) setFile(e.target.files[0]); $('file-input').value = ''; });

  const dz = $('drop-zone');
  ['dragenter','dragover'].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.add('dragging'); }));
  ['dragleave','drop'].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.remove('dragging'); }));
  dz.addEventListener('drop', e => { const f = e.dataTransfer?.files[0]; if (f?.type === 'application/pdf') setFile(f); else setStatus('Please drop a PDF file.', true); });

  $('pw-input').addEventListener('input', validateBtn);
  $('pw-confirm').addEventListener('input', validateBtn);

  $('toggle-vis').addEventListener('click', () => {
    const inp = $('pw-input'); const conf = $('pw-confirm');
    const show = inp.type === 'password';
    inp.type = conf.type = show ? 'text' : 'password';
  });

  $('process-btn').addEventListener('click', async () => {
    const pw = $('pw-input').value;
    if (!pdfFile || !pw) return;
    $('process-btn').disabled = true; $('spinner').classList.remove('hidden'); $('btn-label').textContent = 'Protecting…';
    setStatus('Encrypting PDF…');

    try {
      const { PDFDocument } = await import('https://esm.sh/pdf-lib@1.17.1');
      const bytes = await pdfFile.arrayBuffer();
      const doc = await PDFDocument.load(bytes, { ignoreEncryption: true });
      const outBytes = await doc.save({
        userPassword: pw,
        ownerPassword: pw + '_owner',
        permissions: {
          printing: 'highResolution',
          modifying: false,
          copying: false,
          annotating: false,
          fillingForms: true,
          contentAccessibility: true,
          documentAssembly: false,
        },
      });
      const blob = new Blob([outBytes], { type: 'application/pdf' });
      const base = pdfFile.name.replace(/\.pdf$/i, '');
      const outName = `${base}-protected.pdf`;
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a'); a.href = url; a.download = outName;
      document.body.appendChild(a); a.click(); a.remove();
      URL.revokeObjectURL(url);
      setStatus(`Done — ${outName} downloaded with password protection.`);
    } catch (err) {
      console.error(err);
      setStatus('Failed to protect PDF. The file may be corrupted or use unsupported encryption.', true);
    }

    $('spinner').classList.add('hidden'); $('btn-label').textContent = 'Protect PDF'; $('process-btn').disabled = false;
  });
</script>
